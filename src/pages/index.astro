---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import HeroSection from '../components/HeroSection.astro';
import Manifesto from '../components/Manifesto.astro';
import Capabilities from '../components/Capabilities.astro';
import WordScroll from '../components/WordScroll.astro';
import ScrollGrid from '../components/ScrollGrid.astro';
import Products from '../components/Products.astro';
import SpiralSection from '../components/SpiralSection.astro';
import CoreTeam from '../components/CoreTeam.astro';
import FooterCTA from '../components/FooterCTA.astro';
---

<Layout>
  <Navbar />
  <main id="main-content" class="w-full bg-bg text-white">
    <HeroSection />
    <Manifesto />
    <Capabilities />
    <!-- Connector: Capabilities → WordScroll -->
    <div class="section-connector"><div class="connector-line"></div><div class="connector-dot"></div></div>
    <WordScroll />
    <!-- Connector: WordScroll → ScrollGrid -->
    <div class="section-connector"><div class="connector-line"></div><div class="connector-dot"></div></div>
    <ScrollGrid />
    <!-- Connector: ScrollGrid → Products -->
    <div class="section-connector"><div class="connector-line"></div><div class="connector-dot"></div></div>
    <Products />
    <!-- Gradient bridge: Products → Spiral (most jarring transition) -->
    <div class="relative z-20 h-24 bg-gradient-to-b from-bg via-bg/80 to-bg pointer-events-none"></div>
    <SpiralSection />
    <!-- Connector: Spiral → CoreTeam -->
    <div class="section-connector"><div class="connector-line"></div><div class="connector-dot"></div></div>
    <CoreTeam />
    <FooterCTA />
  </main>

  <!-- Animate section connectors -->
  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.querySelectorAll('.section-connector').forEach((conn) => {
        const dot = conn.querySelector('.connector-dot');

        gsap.to(conn, {
          transform: 'scaleY(1)',
          scrollTrigger: {
            trigger: conn,
            start: 'top 85%',
            end: 'top 50%',
            scrub: 0.5,
          },
        });

        if (dot) {
          gsap.to(dot, {
            opacity: 1,
            scrollTrigger: {
              trigger: conn,
              start: 'top 50%',
              toggleActions: 'play none none reverse',
            },
          });
        }
      });
    } else {
      // Reduced motion: show connectors immediately
      document.querySelectorAll('.section-connector').forEach((conn) => {
        (conn as HTMLElement).style.transform = 'scaleY(1)';
        const dot = conn.querySelector('.connector-dot') as HTMLElement;
        if (dot) dot.style.opacity = '1';
      });
    }
  </script>
</Layout>
