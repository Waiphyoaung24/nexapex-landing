---
// Hero section — full-viewport, bottom-anchored headline with clip-path reveals
// Mobile-first responsive: text scales from 2rem (375px) to 5.5rem (1440px+)
---

<section id="hero" class="relative z-10 w-full h-[100svh] overflow-hidden">
  <!-- Crosshair markers — ambient spatial detail (hidden on mobile for cleanliness) -->
  <div class="absolute inset-0 pointer-events-none hidden md:block" aria-hidden="true">
    <span class="crosshair" style="top: 46%; left: 5%;">+</span>
    <span class="crosshair" style="top: 46%; left: 28%;">+</span>
    <span class="crosshair" style="top: 46%; left: 66%;">+</span>
    <span class="crosshair" style="top: 46%; left: 93%;">+</span>
    <span class="crosshair" style="top: 22%; left: 48%;">+</span>
    <span class="crosshair" style="top: 70%; left: 82%;">+</span>
  </div>

  <!-- Subtle radial glow behind center — where 3D model will go -->
  <div
    class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] md:w-[600px] md:h-[600px] rounded-full opacity-0"
    id="hero-glow"
    style="background: radial-gradient(circle, rgba(90,200,203,0.06) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <!-- Bottom text container — flex-col on mobile, row on desktop -->
  <div class="absolute bottom-0 left-0 right-0 px-5 md:px-10 lg:px-14 pb-20 md:pb-20 flex flex-col md:flex-row md:items-end md:justify-between gap-6 md:gap-8">
    <!-- Left — main headline -->
    <div class="flex-1 min-w-0">
      <h1 class="font-d leading-[0.92] tracking-[-0.02em]">
        <span class="hero-line block overflow-hidden">
          <span class="hero-line-inner block text-[clamp(2rem,6vw,5.5rem)] text-overlay-display">WE ARE</span>
        </span>
        <span class="hero-line block overflow-hidden">
          <span class="hero-line-inner block text-[clamp(2rem,6vw,5.5rem)] text-overlay-display">NEXAPEX</span>
        </span>
        <span class="hero-line block overflow-hidden">
          <span class="hero-line-inner block text-[clamp(2rem,6vw,5.5rem)] text-overlay-display">AN AI</span>
        </span>
        <span class="hero-line block overflow-hidden">
          <span class="hero-line-inner block text-[clamp(2rem,6vw,5.5rem)] italic text-cyan-dim whitespace-nowrap">INNOVATION LAB</span>
        </span>
      </h1>
    </div>

    <!-- Right — tagline (visible on tablet+) -->
    <div class="hidden md:block text-right shrink-0 mb-1">
      <p class="font-d italic text-white leading-[1] tracking-[-0.02em]">
        <span class="hero-line block overflow-hidden">
          <span class="mr-10 hero-line-inner block text-[clamp(1.2rem,2.5vw,2.4rem)]">NICE TO</span>
        </span>
        <span class="hero-line block overflow-hidden">
          <span class="mr-10 hero-line-inner block text-[clamp(1.2rem,2.5vw,2.4rem)]">MEET YOU</span>
        </span>
      </p>
    </div>
  </div>

  <!-- Scroll indicator — centered, above the bottom text on mobile -->
  <div class="absolute bottom-6 md:bottom-4 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 opacity-0 z-20" id="scroll-hint">
    <span class="font-m text-[9px] text-dim uppercase tracking-[0.3em]">Scroll</span>
    <span class="w-px h-6 bg-gradient-to-b from-cyan-dim/50 to-transparent"></span>
  </div>
</section>

<style>
  .crosshair {
    position: absolute;
    color: rgba(255, 255, 255, 0.12);
    font-family: 'Courier New', monospace;
    font-size: 0.85rem;
    font-weight: 300;
    line-height: 1;
    user-select: none;
  }
</style>

<!-- Hero GSAP timeline entrance -->
<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (prefersReducedMotion) {
    gsap.set('.hero-line-inner', { y: 0 });
    gsap.set('.crosshair', { opacity: 0.12 });
    gsap.set('#hero-glow', { opacity: 1 });
    gsap.set('#scroll-hint', { opacity: 1 });
  } else {
    const tl = gsap.timeline({ delay: 0.6 });

    // 1. Hero lines slide up from below their clip containers
    tl.fromTo('.hero-line-inner',
      { yPercent: 110 },
      {
        yPercent: 0,
        duration: 1,
        stagger: 0.08,
        ease: 'power4.out',
      }
    );

    // 2. Crosshairs fade in
    tl.fromTo('.crosshair',
      { opacity: 0, scale: 0.5 },
      {
        opacity: 0.12,
        scale: 1,
        duration: 1.2,
        stagger: 0.06,
        ease: 'power2.out',
      },
      '-=0.6'
    );

    // 3. Center glow pulses in
    tl.to('#hero-glow', {
      opacity: 1,
      duration: 2,
      ease: 'power2.inOut',
    }, '-=1');

    // 4. Scroll hint fades in last
    tl.to('#scroll-hint', {
      opacity: 1,
      duration: 1,
      ease: 'power2.out',
    }, '-=0.5');

    // 5. Scroll-out: hero content slides down + fades
    gsap.to('#hero', {
      yPercent: 15,
      opacity: 0,
      ease: 'none',
      scrollTrigger: {
        trigger: '#hero',
        start: 'bottom bottom',
        end: 'bottom top',
        scrub: 1.5,
      },
    });
  }
</script>
