---
// Hero section — full-viewport with bottom-anchored text
---

<section id="hero" class="relative w-full h-screen overflow-hidden">
  <!-- Crosshair markers scattered across the viewport -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <span class="crosshair" style="top: 48%; left: 5%;">+</span>
    <span class="crosshair" style="top: 48%; left: 30%;">+</span>
    <span class="crosshair" style="top: 48%; left: 68%;">+</span>
    <span class="crosshair" style="top: 48%; left: 92%;">+</span>
  </div>

  <!-- Bottom text container -->
  <div class="absolute bottom-0 left-0 right-0 px-6 md:px-10 lg:px-14 pb-8 md:pb-12 flex items-end justify-between">
    <!-- Left — main headline -->
    <div class="hero-text-left" data-hero-text="left">
      <h1 class="font-d text-white leading-[0.95] tracking-tight">
        <span class="block text-[clamp(2rem,7vw,5.5rem)]">WE ARE</span>
        <span class="block text-[clamp(2rem,7vw,5.5rem)]">NEXAPEX</span>
        <span class="block text-[clamp(2rem,7vw,5.5rem)]">AN AI</span>
        <span class="block text-[clamp(2rem,7vw,5.5rem)] italic text-cyan-dim">INNOVATION LAB</span>
      </h1>
    </div>

    <!-- Right — tagline -->
    <div class="hero-text-right hidden md:block text-right" data-hero-text="right">
      <p class="font-d italic text-white text-[clamp(1.5rem,4vw,3.5rem)] leading-[0.95] tracking-tight">
        <span class="block">NICE TO</span>
        <span class="block">MEET YOU</span>
      </p>
    </div>
  </div>
</section>

<style>
  .crosshair {
    position: absolute;
    color: rgba(255, 255, 255, 0.15);
    font-family: monospace;
    font-size: 1rem;
    line-height: 1;
    user-select: none;
  }
</style>

<!-- Hero text entrance animation -->
<script>
  import gsap from 'gsap';

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    // Left text — stagger lines from bottom
    const leftLines = document.querySelectorAll('[data-hero-text="left"] h1 span');
    gsap.fromTo(leftLines,
      { y: 80, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 1.2,
        stagger: 0.1,
        ease: 'power4.out',
        delay: 0.3,
      }
    );

    // Right text — fade in slightly later
    const rightLines = document.querySelectorAll('[data-hero-text="right"] p span');
    gsap.fromTo(rightLines,
      { y: 50, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 1.2,
        stagger: 0.1,
        ease: 'power4.out',
        delay: 0.7,
      }
    );

    // Crosshairs fade in
    gsap.fromTo('.crosshair',
      { opacity: 0 },
      {
        opacity: 0.15,
        duration: 2,
        stagger: 0.15,
        ease: 'power2.out',
        delay: 1.2,
      }
    );
  } else {
    gsap.set('[data-hero-text] span', { opacity: 1, y: 0 });
  }
</script>
