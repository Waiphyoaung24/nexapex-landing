---
// Static HTML for all fallback states — JS determines which to show
import Logo3D from '../Logo3D.astro';
---

<!-- Loader overlay -->
<div
  id="cinematic-loader"
  class="fixed inset-0 z-[10000] flex flex-col items-center justify-center bg-bg transition-opacity duration-500"
>
  <div class="w-48 h-[2px] bg-white/10 rounded-full overflow-hidden">
    <div
      class="h-full bg-gradient-to-r from-cyan/60 to-cyan rounded-full"
      style="animation: loaderBar 1.5s ease-in-out infinite; box-shadow: 0 0 8px rgba(148, 252, 255, 0.5);"
    ></div>
  </div>
  <p class="font-m text-[10px] tracking-[3px] uppercase text-dim mt-4">Loading Experience</p>
</div>

<!-- 3D Canvas wrapper (desktop/tablet) — starts hidden, revealed after cinematic load -->
<div
  id="canvas-wrapper"
  class="fixed inset-0 w-full h-screen z-0"
  style="display: none; opacity: 0;"
>
  <canvas id="cinematic-canvas" style="width: 100%; height: 100%; display: block;"></canvas>
</div>

<!-- Animated WebGL 3D Glow Logo — centered in hero -->
<div
  id="hero-logo3d"
  class="fixed inset-0 z-[6] flex items-center justify-center pointer-events-none"
  style="display: none;"
>
  <div class="w-full h-full">
    <Logo3D />
  </div>
</div>


<!-- Scroll arrow indicator -->
<div id="scroll-arrow" class="fixed max-md:bottom-8 max-md:left-1/2 max-md:-translate-x-1/2 md:left-6 md:top-1/2 md:-translate-y-1/2 z-40 pointer-events-none" style="display: none;">
  <div class="flex flex-col items-center gap-4">
    <svg width="24" height="32" viewBox="0 0 24 32">
      <path
        d="M 12 4 L 12 24 M 12 24 L 8 20 M 12 24 L 16 20"
        stroke="currentColor"
        stroke-width="0.5"
        fill="none"
        class="text-white/60"
        style="filter: drop-shadow(0 0 4px rgba(255,255,255,0.3));"
      />
    </svg>
    <div class="w-1 h-1 rounded-full bg-white/40" style="box-shadow: 0 0 6px rgba(255,255,255,0.4);"></div>
  </div>
</div>

<!-- Gradient bridge (transition zone) -->
<div
  id="gradient-bridge"
  class="fixed bottom-0 left-0 right-0 h-[40vh] z-[5] pointer-events-none opacity-0"
  style="background: linear-gradient(to bottom, transparent, #0e1418 70%); display: none;"
></div>

<!-- Logo prelude (desktop — scroll-driven reveal) -->
<div id="cube-section" class="relative z-10" style="display: none;">
  <div id="prelude-scroll" class="relative" style="height: 0;">
    <!-- Removed prelude content as 3D logo is now the primary visual -->
  </div>
</div>

<!-- Scroll trigger container (responsive height) -->
<div id="scroll-container" class="relative z-20" style="height: 700vh; display: none;"></div>

<!-- Mobile fallback (no WebGL) -->
<div id="mobile-fallback" class="relative" style="height: 320vh; display: none;">
  <div id="mobile-panel" class="h-screen flex flex-col items-center justify-center overflow-hidden"
    style="background: radial-gradient(ellipse at 50% 40%, rgba(26,38,48,0.6), #0e1418 70%);"
  >
    <div id="mobile-hero-content" class="flex flex-col items-center text-center px-6">
      <div class="mobile-hero-logo w-24 h-24 mb-10">
        <img
          src="/outline_iconmark.png"
          alt="NexApex"
          class="w-full h-full object-contain"
          loading="eager"
        />
      </div>
      <p class="font-m text-[11px] tracking-[0.45em] text-dim drop-shadow-lg mb-3">AI LABS FOR REAL-WORLD OPERATIONS</p>
      <h1 class="font-d font-bold leading-[1.1] tracking-[0.02em] text-gradient-hero mt-5"
        style="font-size: clamp(32px, 10vw, 52px);"
      >
        THE APEX OF<br />INTELLIGENCE
      </h1>
    </div>

    <!-- Scene 1: INTELLIGENCE -->
    <div class="mobile-text absolute flex flex-col items-center text-center px-8 opacity-0" style="top: 45%;">
      <p class="font-d font-bold tracking-tight text-gradient-hero drop-shadow-2xl" style="font-size: clamp(28px, 9vw, 40px);">INTELLIGENCE</p>
      <p class="font-b text-sm text-white/80 font-light mt-2 tracking-[0.1em] drop-shadow-lg">Systems That Learn, Adapt &amp; Decide</p>
    </div>

    <!-- Scene 2: INTEGRATION -->
    <div class="mobile-text absolute flex flex-col items-center text-center px-8 opacity-0" style="top: 45%;">
      <p class="font-d font-bold tracking-tight text-gradient-hero drop-shadow-2xl" style="font-size: clamp(28px, 9vw, 40px);">INTEGRATION</p>
      <p class="font-b text-sm text-white/80 font-light mt-2 tracking-[0.1em] drop-shadow-lg">Connecting Digital Systems to Physical Operations</p>
    </div>

    <!-- Scene 3: OPTIMIZATION -->
    <div class="mobile-text absolute flex flex-col items-center text-center px-8 opacity-0" style="top: 45%;">
      <p class="font-d font-bold tracking-tight text-gradient-hero drop-shadow-2xl" style="font-size: clamp(28px, 9vw, 40px);">OPTIMIZATION</p>
      <p class="font-b text-sm text-white/80 font-light mt-2 tracking-[0.1em] drop-shadow-lg">Data-Driven Decisions at Every Layer</p>
    </div>

    <!-- Scene 4: REACH THE PEAK -->
    <div class="mobile-text absolute flex flex-col items-center text-center px-8 opacity-0" style="top: 45%;">
      <p class="font-d font-bold tracking-tight text-gradient-hero drop-shadow-2xl" style="font-size: clamp(28px, 9vw, 40px);">REACH THE PEAK</p>
      <p class="font-b text-sm text-white/80 font-light mt-2 tracking-[0.1em] drop-shadow-lg">NEX APEX</p>
    </div>

    <!-- Scene 5: FINALE — WHERE AI MEETS REALITY -->
    <div class="mobile-text mobile-text-finale absolute flex flex-col items-center text-center px-8 opacity-0" style="top: 38%;">
      <h2 class="font-d font-bold text-gradient-hero leading-[1.05]"
        style="font-size: clamp(36px, 11vw, 56px); letter-spacing: 0.02em;"
      >
        WHERE AI<br />MEETS REALITY
      </h2>
      <p class="font-b text-sm text-dim mt-4 tracking-wide leading-[1.6] max-w-[280px]">
        Built for Real-World Operations Across Southeast Asia
      </p>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-3">
      <div class="w-px h-10 bg-gradient-to-b from-cyan/40 to-transparent animate-pulse-line"></div>
      <span class="font-m text-[9px] tracking-[0.3em] uppercase text-dim/50">Scroll</span>
    </div>
  </div>
</div>

<!-- Reduced motion fallback -->
<div id="reduced-motion-fallback" class="relative flex flex-col items-center justify-center" style="height: 100vh; display: none; background: radial-gradient(ellipse at 50% 40%, rgba(26,38,48,0.6), #0e1418 70%);">
  <div class="w-32 h-32 mb-8" style="filter: drop-shadow(0 0 50px rgba(148,252,255,0.1));">
    <img src="/full_color_logo.svg" alt="NexApex" class="w-full h-full object-contain" />
  </div>
  <p class="font-m text-[11px] md:text-[0.85vw] tracking-[0.45em] text-dim drop-shadow-lg mb-3">AI LABS FOR REAL-WORLD OPERATIONS</p>
  <h1 class="font-d font-bold text-gradient-hero text-center px-6 leading-[1.05] mt-5"
    style="font-size: clamp(32px, 5.8vw, 84px); letter-spacing: 0.02em;"
  >
    THE APEX OF<br />INTELLIGENCE
  </h1>
</div>

<!-- ═══ Prelude section styles ═══ -->
<style is:global>
  /* Mobile hero animated logo */
  .mobile-hero-logo {
    animation: mobileLogo 4s ease-in-out infinite;
    filter: drop-shadow(0 0 24px rgba(148, 252, 255, 0.25))
            drop-shadow(0 0 60px rgba(148, 252, 255, 0.1));
  }

  @keyframes mobileLogo {
    0%, 100% {
      filter: drop-shadow(0 0 24px rgba(148, 252, 255, 0.25))
              drop-shadow(0 0 60px rgba(148, 252, 255, 0.1));
      transform: scale(1);
    }
    50% {
      filter: drop-shadow(0 0 36px rgba(148, 252, 255, 0.45))
              drop-shadow(0 0 80px rgba(148, 252, 255, 0.2));
      transform: scale(1.04);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-hero-logo {
      animation: none;
    }
  }

  /* Logo */
  .prelude-logo {
    margin-bottom: 2rem;
    opacity: 0;
    transform: scale(0.7);
  }

  .prelude-logo img {
    width: 220px;
    height: 220px;
    object-fit: contain;
    filter: drop-shadow(0 0 60px rgba(148, 252, 255, 0.12));
    user-select: none;
  }

  /* All text lines start hidden */
  .prelude-line {
    opacity: 0;
    transform: translateY(16px);
  }

  #prelude-brand {
    margin-bottom: 1rem;
  }

  #prelude-pillars {
    margin-bottom: 0.75rem;
  }

  .prelude-pillar {
    font-family: var(--font-b);
    font-size: 13px;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.5);
  }

  .prelude-dot {
    color: rgba(148, 252, 255, 0.3);
    font-size: 16px;
  }

  .prelude-divider {
    width: 32px;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(148, 252, 255, 0.25));
  }

  .prelude-divider-end {
    background: linear-gradient(to left, transparent, rgba(148, 252, 255, 0.25));
  }

  /* Subtle grid overlay */
  #cube-section::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at 50% 40%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at 50% 40%, black 20%, transparent 70%);
    z-index: -1;
  }
</style>

<!-- ═══ Cinematic Hero script ═══ -->
<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // ── Global bridge for logo shatter completion ──
  declare global {
    interface Window {
      __logoShatterComplete?: boolean;
      __onLogoShatterComplete?: () => void;
    }
  }

  function getDeviceTier(): 'desktop' | 'tablet' | 'mobile' {
    const width = window.innerWidth;
    if (width < 768) return 'mobile';
    if (width < 1024) return 'tablet';
    return 'desktop';
  }

  function hasWebGL2(): boolean {
    try {
      const canvas = document.createElement('canvas');
      return !!canvas.getContext('webgl2');
    } catch { return false; }
  }

  function prefersReducedMotion(): boolean {
    return window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  }

  const loader = document.getElementById('cinematic-loader')!;
  const canvasWrapper = document.getElementById('canvas-wrapper')!;
  const heroLogo3d = document.getElementById('hero-logo3d')!;
  const scrollArrow = document.getElementById('scroll-arrow')!;
  const gradientBridge = document.getElementById('gradient-bridge')!;
  const cubeSection = document.getElementById('cube-section')!;
  const scrollContainer = document.getElementById('scroll-container')!;
  const mobileFallback = document.getElementById('mobile-fallback')!;
  const reducedMotionFallback = document.getElementById('reduced-motion-fallback')!;

  const ssrLoader = document.getElementById('ssr-loader');
  if (ssrLoader) ssrLoader.remove();

  const deviceTier = getDeviceTier();
  const webgl2 = hasWebGL2();
  const reducedMotion = prefersReducedMotion();

  if (reducedMotion) {
    loader.remove();
    reducedMotionFallback.style.display = '';
  } else if (!webgl2 || deviceTier === 'mobile') {
    // Mobile gets lightweight fallback — 3D engine causes scroll lag
    loader.remove();
    mobileFallback.style.display = '';
    initMobileFallback();
  } else {
    heroLogo3d.style.display = '';
    scrollArrow.style.display = '';
    gradientBridge.style.display = '';
    cubeSection.style.display = '';
    scrollContainer.style.display = '';
    canvasWrapper.style.display = '';
    initCinematicHero();
  }

  function triggerLogoShatter() {
    if (window.__logo3dPlayShatter) {
      window.__logo3dPlayShatter();
    } else {
      (window as any).__logo3dTriggerShatter = true;
    }
  }

  /**
   * Set up scroll-driven transitions after cinematic engine loads.
   */
  function setupScrollDrivenTransition(engine: any) {
    // Set up the engine scroll timeline and other scroll features immediately
    engine.setupScrollTimeline(canvasWrapper, gradientBridge, scrollArrow);

    // Show cinematic canvas immediately
    canvasWrapper.style.opacity = '1';

    // ── Scroll-driven Logo Fade Out ──
    ScrollTrigger.create({
      trigger: scrollContainer,
      start: 'top top',
      end: '10% top',
      scrub: 2,
      onUpdate: (self: any) => {
        const p = self.progress;
        heroLogo3d.style.opacity = String(1 - p);
        heroLogo3d.style.transform = `scale(${1 + p * 0.05 - p * p * 0.15})`;

        if (p >= 0.98) {
          heroLogo3d.style.display = 'none';
        } else {
          heroLogo3d.style.display = '';
        }
      },
    });

    import('./cube-scroll').then(({ initCubeScroll }) => {
      initCubeScroll();
    });

    import('./text-overlays').then(({ createTextOverlays, initTextAnimations }) => {
      const textElements = createTextOverlays(document.body);
      initTextAnimations(textElements, scrollContainer);
    });

    import('./progress-bar').then(({ createProgressBar, initProgressBar }) => {
      createProgressBar(document.body);
      initProgressBar(scrollContainer);
    });
  }

  function initMobileFallback() {
    const heroContent = document.getElementById('mobile-hero-content')!;
    const stickyPanel  = document.getElementById('mobile-panel')!;
    const scrollHint   = mobileFallback.querySelector<HTMLElement>('.absolute.bottom-8')!;
    const mobileTexts  = mobileFallback.querySelectorAll<HTMLElement>('.mobile-text');

    // ── 0. Pin the panel for the full 320vh using GSAP (fixes CSS sticky math) ──
    // CSS sticky releases early when panel bottom exits the parent container.
    // GSAP pin uses position:fixed internally and stays locked for the full range.
    ScrollTrigger.create({
      trigger: mobileFallback,
      start: 'top top',
      end: 'bottom top',
      pin: stickyPanel,
      pinSpacing: false,
      anticipatePin: 1,
    });

    // ── 1. Hero: fade + lift out by 16% ──────────────────────────────────
    gsap.to(heroContent, {
      opacity: 0,
      y: -36,
      ease: 'none',
      scrollTrigger: {
        trigger: mobileFallback,
        start: 'top top',
        end: '16% top',
        scrub: 0.4,
      },
    });

    // Scroll hint fades earlier (users have started scrolling)
    gsap.to(scrollHint, {
      opacity: 0,
      ease: 'none',
      scrollTrigger: {
        trigger: mobileFallback,
        start: '3% top',
        end: '10% top',
        scrub: 0.4,
      },
    });

    // ── 2. Sequential text scenes: 18% → 86% (each scene = ~13.6%) ──────
    // Layout: in(35%) — hold(30%) — out(35%) per scene
    // Finale (last): in(40%) only — then panel dissolves
    const totalTexts = mobileTexts.length;  // 5
    const RANGE_START = 18;
    const RANGE_END   = 86;
    const sceneStep   = (RANGE_END - RANGE_START) / totalTexts; // ≈13.6 %

    mobileTexts.forEach((el, i) => {
      const isFinale   = i === totalTexts - 1;
      const sceneStart = RANGE_START + i * sceneStep;
      const sceneEnd   = sceneStart + sceneStep;

      if (isFinale) {
        // WHERE AI MEETS REALITY — fade in, stay; panel handles the exit
        gsap.fromTo(el,
          { opacity: 0, y: 22, scale: 0.97 },
          {
            opacity: 1, y: 0, scale: 1,
            ease: 'none',
            scrollTrigger: {
              trigger: mobileFallback,
              start: `${sceneStart}% top`,
              end: `${sceneStart + sceneStep * 0.45}% top`,
              scrub: 0.5,
            },
          },
        );
      } else {
        // in → hold → out (proportional durations inside timeline)
        const tl = gsap.timeline({
          scrollTrigger: {
            trigger: mobileFallback,
            start: `${sceneStart}% top`,
            end: `${sceneEnd}% top`,
            scrub: 0.4,
          },
        });
        tl
          .fromTo(el,
            { opacity: 0, y: 22 },
            { opacity: 1, y: 0, ease: 'none', duration: 0.35 },
          )
          .to(el, { opacity: 1, y: 0, ease: 'none', duration: 0.30 })
          .to(el, { opacity: 0, y: -22, ease: 'none', duration: 0.35 });
      }
    });

    // ── 3. Cinematic dissolve → next section (87% → 100%) ────────────────
    // Fades the entire sticky panel so content below is revealed as the
    // user scrolls through the final stretch of the hero section.
    gsap.to(stickyPanel, {
      opacity: 0,
      ease: 'none',
      scrollTrigger: {
        trigger: mobileFallback,
        start: '87% top',
        end: '100% top',
        scrub: 0.6,
      },
    });
  }

  async function initCinematicHero() {
    const canvas = document.getElementById('cinematic-canvas') as HTMLCanvasElement;
    const particleCount = deviceTier === 'mobile' ? 200 : deviceTier === 'tablet' ? 400 : 800;
    const dpr: [number, number] = deviceTier === 'mobile' ? [1, 1] : deviceTier === 'tablet' ? [1, 1.5] : [1, 2];


    const { CinematicEngine } = await import('./cinematic-engine');

    await new Promise<void>((resolve) => {
      setTimeout(() => {
        if (document.fonts && document.fonts.ready) {
          document.fonts.ready.then(() => resolve());
        } else {
          resolve();
        }
      }, 1500);
    });

    const engine = new CinematicEngine({
      canvas,
      scrollContainer,
      particleCount,
      dpr,
      onLoaded: () => {
        // Use queueMicrotask to avoid TDZ — on mobile, onLoaded fires synchronously
        // during the CinematicEngine constructor, before `engine` is assigned.
        queueMicrotask(() => {
          // Start engine but keep canvas hidden — render warm-up frames
          // so GPU compiles shaders before the user sees anything (prevents lag).
          engine.start();

          // Wait for a few frames to render off-screen, then reveal
          let warmupFrames = 0;
          const warmupTarget = deviceTier === 'mobile' ? 8 : 4;
          function onWarmup() {
            warmupFrames++;
            if (warmupFrames < warmupTarget) {
              requestAnimationFrame(onWarmup);
              return;
            }
            // GPU is warm — reveal everything
            loader.style.opacity = '0';
            setTimeout(() => loader.remove(), 600);
            triggerLogoShatter();
            setupScrollDrivenTransition(engine);
          }
          requestAnimationFrame(onWarmup);
        });
      },
    });

    canvasWrapper.addEventListener('mousemove', (e) => {
      const x = (e.clientX / window.innerWidth) * 2 - 1;
      const y = (e.clientY / window.innerHeight) * 2 - 1;
      engine.onMouseMove(x, y);
    });
  }
</script>
