---
const currentYear = new Date().getFullYear();
const navItems = [
  { label: 'Services', href: '#services' },
  { label: 'Process', href: '#process' },
  { label: 'Products', href: '#work' },
  { label: 'About', href: '#about' },
  { label: 'Contact', href: '#contact' },
];
---

<footer class="border-t border-cyan-subtle py-16 px-6 md:px-12">
  <div class="max-w-[1400px] mx-auto">
    <div class="grid md:grid-cols-3 gap-12 mb-16">
      <!-- Logo + tagline -->
      <div>
        <a href="/" class="inline-flex items-center gap-5 mb-4 cursor-pointer no-underline">
          <div class="relative w-10 h-10">
            <img
              src="/White_iconmark.png"
              alt="NexApex"
              width="40"
              height="40"
              class="object-contain w-full h-full"
            />
          </div>
          <span class="font-d text-[12px] tracking-[2px] uppercase text-sage/70">
            Nex Apex
          </span>
        </a>
        <p class="font-b text-sm text-dim leading-[1.6]">
          AI Labs deploying intelligence into digital systems and physical operations across Southeast Asia.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="font-m text-[11px] tracking-[3px] uppercase text-mauve mb-6">Navigation</h4>
        <ul class="space-y-3 list-none p-0 m-0">
          {navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="font-b text-sm text-dim no-underline transition-colors duration-300 hover:text-cyan cursor-pointer"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact + Social -->
      <div>
        <h4 class="font-m text-[11px] tracking-[3px] uppercase text-mauve mb-6">Connect</h4>
        <div class="space-y-3 mb-8">
          <p class="font-b text-sm text-dim">hello@nexapex.ai</p>
          <p class="font-b text-sm text-dim">Bangkok, Thailand</p>
        </div>

        <!-- Social links -->
        <div class="flex gap-4">
          <!-- LinkedIn -->
          <a
            href="https://linkedin.com/company/nexapex"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="w-9 h-9 flex items-center justify-center border border-cyan-subtle rounded-lg text-dim transition-all duration-300 hover:text-cyan hover:border-cyan/30 cursor-pointer"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </a>
          <!-- GitHub -->
          <a
            href="https://github.com/nexapex"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="w-9 h-9 flex items-center justify-center border border-cyan-subtle rounded-lg text-dim transition-all duration-300 hover:text-cyan hover:border-cyan/30 cursor-pointer"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
            </svg>
          </a>
          <!-- X (Twitter) -->
          <a
            href="https://x.com/nexapex"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="X"
            class="w-9 h-9 flex items-center justify-center border border-cyan-subtle rounded-lg text-dim transition-all duration-300 hover:text-cyan hover:border-cyan/30 cursor-pointer"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-cyan-subtle flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="font-m text-[11px] text-dim tracking-[2px] uppercase">
        &copy; {currentYear} NexApex. All rights reserved.
      </p>
      <p class="font-m text-[10px] text-dim/50 tracking-[1px]">
        Built at the apex.
      </p>
    </div>
  </div>
</footer>
