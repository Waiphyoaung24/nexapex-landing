---
// CoreTeam — scroll-driven 3D cube gallery introducing leadership
// Each cube face shows a team member photo; text cards scroll alongside
const team = [
  {
    name: 'Zwe Paing Htet',
    title: 'Founder & CEO',
    short: 'FOUNDER',
    bio: 'Architecting the vision of intelligent systems that redefine how industries operate. Driving NexApex from concept to market across AI-powered verticals.',
    initials: 'ZP',
    pattern: 'concentric',
  },
  {
    name: 'Wai Phyo Aung',
    title: 'Founder & CTO',
    short: 'TECHNOLOGY',
    bio: 'Leading engineering and R&D in computer vision, deep learning, and full-stack AI product development. Building the technical foundation of NexApex.',
    initials: 'WP',
    pattern: 'hexgrid',
  },
  {
    name: 'Wai Yan Hein',
    title: 'Founder & CFO',
    short: 'FINANCE',
    bio: 'Scaling sustainable growth and financial strategy across global AI markets. Ensuring NexApex delivers long-term value and operational excellence.',
    initials: 'WY',
    pattern: 'chevron',
  },
];

const FACE_ORDER = ['front', 'right', 'back', 'left'] as const;
const FACE_NAMES = ['TEAM', ...team.map(m => m.short), 'JOIN US'];
---

<section class="ct-wrap" id="core-team">
  <!-- Top gradient bridge for smooth entry -->
  <div class="absolute top-0 left-0 right-0 h-24 bg-gradient-to-b from-bg to-transparent pointer-events-none z-30"></div>
  <div class="ct-viewport">
    <!-- 3D Cube -->
    <div class="ct-scene">
      <div class="ct-cube" id="ct-cube">
        <div class="ct-face" data-face="top">
          <span class="ct-face-label font-d">TEAM</span>
        </div>
        {team.map((m, i) => (
          <div class="ct-face" data-face={FACE_ORDER[i]}>
            <div class={`ct-face-geo ct-geo-${m.pattern}`} aria-label={m.name}>
              <span class="ct-face-initials font-d">{m.initials}</span>
            </div>
          </div>
        ))}
        <div class="ct-face" data-face="bottom">
          <span class="ct-face-label font-d">JOIN</span>
        </div>
      </div>
    </div>

    <!-- Text card overlay — JS toggles .ct-active per panel -->
    <div class="ct-overlay">
      <!-- Panel 0: Intro -->
      <div class="ct-panel ct-active" data-panel="0">
        <div class="ct-card">
          <div class="ct-tag font-m">Our Core Team</div>
          <h2 class="ct-heading font-d">THE<br/>MINDS<br/>BEHIND</h2>
          <p class="ct-body font-b">
            Four leaders. One mission.<br/>
            Building intelligent systems that transform industries from the ground up.
          </p>
        </div>
      </div>

      <!-- Panels 1–4: Team members -->
      {team.map((m, i) => (
        <div class="ct-panel" data-panel={i + 1}>
          <div class:list={['ct-card', i % 2 !== 0 ? 'ct-card--right' : '']}>
            <div class="ct-accent"></div>
            <div class="ct-tag font-m">{`0${i + 1} — ${m.short}`}</div>
            <h2 class="ct-heading font-d" set:html={m.name.toUpperCase().split(' ').join('<br/>')} />
            <p class="ct-role font-m">{m.title}</p>
            <p class="ct-body font-b">{m.bio}</p>
          </div>
        </div>
      ))}

      <!-- Panel 5: Closing -->
      <div class="ct-panel" data-panel="5">
        <div class="ct-card ct-card--right">
          <div class="ct-accent"></div>
          <div class="ct-tag font-m">Join Us</div>
          <h2 class="ct-heading font-d">BUILD<br/>WITH<br/>US</h2>
          <p class="ct-body font-b">
            We're always looking for exceptional minds
            who want to shape the future of AI.
          </p>
          <a
            href="#contact"
            class="ct-cta font-m group"
          >
            Get in Touch
            <span class="inline-block transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
          </a>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  const section = document.getElementById('core-team');
  const cube = document.getElementById('ct-cube');
  const panels = section?.querySelectorAll('.ct-panel');
  const STOPS = [
    { rx:  90, ry:    0 },  // top
    { rx:   0, ry:    0 },  // front
    { rx:   0, ry:  -90 },  // right
    { rx:   0, ry: -180 },  // back
    { rx:   0, ry: -270 },  // left
    { rx: -90, ry: -360 },  // bottom
  ];

  const N = STOPS.length;

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isMobile = window.innerWidth <= 768;

  // Mobile: show all panels visible (CSS handles vertical stacking)
  if (isMobile && panels) {
    panels.forEach((p) => p.classList.add('ct-active'));
  }

  if (!prefersReducedMotion && !isMobile && section && cube && panels) {
    let smooth = 0;
    let lastIdx = -1;
    let rafId = 0;
    let isVisible = false;

    const easeIO = (t: number) => (t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t);

    const tick = () => {
      if (!isVisible) return;

      const rect = section.getBoundingClientRect();
      const scrollable = section.offsetHeight - window.innerHeight;
      const scrolled = Math.max(0, -rect.top);
      const target = Math.min(1, scrolled / Math.max(1, scrollable));

      smooth += (target - smooth) * 0.08;

      // Cube rotation
      const t = smooth * (N - 1);
      const i = Math.min(Math.floor(t), N - 2);
      const f = easeIO(t - i);
      const a = STOPS[i], b = STOPS[i + 1];
      const rx = a.rx + (b.rx - a.rx) * f;
      const ry = a.ry + (b.ry - a.ry) * f;
      cube.style.transform = `rotateX(${rx}deg) rotateY(${ry}deg)`;

      // Active panel
      const si = Math.min(N - 1, Math.floor(smooth * N));
      if (si !== lastIdx) {
        lastIdx = si;
        panels.forEach((p, j) => p.classList.toggle('ct-active', j === si));
      }

      rafId = requestAnimationFrame(tick);
    };

    // Only run RAF when section is in viewport
    const observer = new IntersectionObserver(([entry]) => {
      isVisible = entry.isIntersecting;
      if (isVisible) {
        rafId = requestAnimationFrame(tick);
      } else {
        cancelAnimationFrame(rafId);
      }
    }, { rootMargin: '100px' });

    observer.observe(section);
  }
</script>
