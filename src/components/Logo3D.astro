---
// Logo3D — Voronoi shard assembly animation only
// On load: shards assemble into logo, stays as assembled shatter mesh
---

<div
  id="logo3d-wrapper"
  class="relative flex items-center justify-center"
  style="width: 100%; height: 100%;"
>
  <canvas id="logo3d-shatter" class="absolute inset-0" style="width: 100%; height: 100%; display: block;"></canvas>
</div>

<script>

  // Global bridges
  declare global {
    interface Window {
      __logo3dScroll?: number;
      __logo3dShatterReady?: boolean;
      __logo3dPlayShatter?: () => void;
      __logo3dTriggerShatter?: boolean;
      __logoShatterComplete?: boolean;
      __onLogoShatterComplete?: () => void;
    }
  }

  // Bail out on mobile — no 3D loading at all
  const isMobile = window.innerWidth < 768
    || ('ontouchstart' in window && window.innerWidth < 1024);

  if (isMobile) {
    // No-op shatter bridge so CinematicHero doesn't wait forever
    window.__logo3dShatterReady = true;
    window.__logo3dPlayShatter = () => {
      window.__logoShatterComplete = true;
      if (window.__onLogoShatterComplete) window.__onLogoShatterComplete();
    };
    if (window.__logo3dTriggerShatter) window.__logo3dPlayShatter();
  }

  async function initLogo3D() {
    if (isMobile) return;

    const shatterCanvas = document.getElementById('logo3d-shatter') as HTMLCanvasElement;
    const wrapper = document.getElementById('logo3d-wrapper')!;
    if (!shatterCanvas || !wrapper) return;

    const w = wrapper.clientWidth || 380;
    const h = wrapper.clientHeight || 380;

    // Dynamic import — Three.js + d3-delaunay only downloaded on desktop
    const { createLogoShatter } = await import('./cinematic/logo-shatter');

    createLogoShatter({
      canvas: shatterCanvas,
      logoUrl: '/outline_iconmark.png',
      width: w,
      height: h,
      duration: 3.5,
      baseSplinters: 35,
      tinySplinters: 1200,
      splinterGrouping: 0.55,
      explosionStrength: 4.5,
      rotationStrength: 18.0,
      onComplete: () => {
        // Signal to CinematicHero that logo shatter assembly is done
        window.__logoShatterComplete = true;
        if (window.__onLogoShatterComplete) {
          window.__onLogoShatterComplete();
        }
      },
    }).then((instance) => {
      window.__logo3dShatterReady = true;
      window.__logo3dPlayShatter = () => {
        instance.play();
      };

      if (window.__logo3dTriggerShatter) {
        instance.play();
      }
    }).catch((err) => {
      console.warn('LogoShatter failed:', err);
    });
  }

  // ── Init — handle display:none parent (desktop only) ──
  if (typeof window !== 'undefined' && !isMobile) {
    function tryInit() {
      const wrapper = document.getElementById('logo3d-wrapper');
      if (!wrapper) return;

      if (wrapper.clientWidth > 0 && wrapper.clientHeight > 0) {
        initLogo3D();
        return;
      }

      const heroLogo = document.getElementById('hero-logo3d');
      if (heroLogo) {
        const observer = new MutationObserver(() => {
          if (wrapper!.clientWidth > 0 && wrapper!.clientHeight > 0) {
            observer.disconnect();
            initLogo3D();
          }
        });
        observer.observe(heroLogo, { attributes: true, attributeFilter: ['style'] });
      }

      let attempts = 0;
      const poll = setInterval(() => {
        attempts++;
        if (wrapper!.clientWidth > 0 && wrapper!.clientHeight > 0) {
          clearInterval(poll);
          initLogo3D();
        }
        if (attempts > 120) clearInterval(poll);
      }, 100);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', tryInit);
    } else {
      tryInit();
    }
  }
</script>

<style>
  #logo3d-wrapper {
    filter: drop-shadow(0 0 60px rgba(148, 252, 255, 0.08));
  }

  @media (prefers-reduced-motion: reduce) {
    #logo3d-shatter {
      display: none !important;
    }
    #logo3d-wrapper::after {
      content: '';
      position: absolute;
      inset: 10%;
      background: url('/outline_iconmark.png') center/contain no-repeat;
      filter: drop-shadow(0 0 30px rgba(148, 252, 255, 0.5))
              drop-shadow(0 0 60px rgba(148, 252, 255, 0.3));
    }
  }
</style>
