---
// Logo3D — Voronoi shard assembly animation only
// On load: shards assemble into logo, stays as assembled shatter mesh
---

<div
  id="logo3d-wrapper"
  class="relative flex items-center justify-center"
  style="width: 100%; height: 100%;"
>
  <canvas id="logo3d-shatter" class="absolute inset-0" style="width: 100%; height: 100%; display: block;"></canvas>
</div>

<script>
  import { createLogoShatter } from './cinematic/logo-shatter';

  // Global bridges
  declare global {
    interface Window {
      __logo3dScroll?: number;
      __logo3dShatterReady?: boolean;
      __logo3dPlayShatter?: () => void;
      __logo3dTriggerShatter?: boolean;
    }
  }

  function initLogo3D() {
    const shatterCanvas = document.getElementById('logo3d-shatter') as HTMLCanvasElement;
    const wrapper = document.getElementById('logo3d-wrapper')!;
    if (!shatterCanvas || !wrapper) return;

    const w = wrapper.clientWidth || 380;
    const h = wrapper.clientHeight || 380;
    const isMobile = window.innerWidth < 768;

    createLogoShatter({
      canvas: shatterCanvas,
      logoUrl: '/outline_iconmark.png',
      width: w,
      height: h,
      duration: isMobile ? 2.8 : 3.5,
      baseSplinters: isMobile ? 20 : 35,
      tinySplinters: isMobile ? 400 : 1200,
      splinterGrouping: 0.55,
      explosionStrength: isMobile ? 3.5 : 4.5,
      rotationStrength: isMobile ? 12.0 : 18.0,
    }).then((instance) => {
      window.__logo3dShatterReady = true;
      window.__logo3dPlayShatter = () => {
        instance.play();
      };

      if (window.__logo3dTriggerShatter) {
        instance.play();
      }
    }).catch((err) => {
      console.warn('LogoShatter failed:', err);
    });
  }

  // ── Init — handle display:none parent ──
  if (typeof window !== 'undefined') {
    function tryInit() {
      const wrapper = document.getElementById('logo3d-wrapper');
      if (!wrapper) return;

      if (wrapper.clientWidth > 0 && wrapper.clientHeight > 0) {
        initLogo3D();
        return;
      }

      const heroLogo = document.getElementById('hero-logo3d');
      if (heroLogo) {
        const observer = new MutationObserver(() => {
          if (wrapper!.clientWidth > 0 && wrapper!.clientHeight > 0) {
            observer.disconnect();
            initLogo3D();
          }
        });
        observer.observe(heroLogo, { attributes: true, attributeFilter: ['style'] });
      }

      let attempts = 0;
      const poll = setInterval(() => {
        attempts++;
        if (wrapper!.clientWidth > 0 && wrapper!.clientHeight > 0) {
          clearInterval(poll);
          initLogo3D();
        }
        if (attempts > 120) clearInterval(poll);
      }, 100);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', tryInit);
    } else {
      tryInit();
    }
  }
</script>

<style>
  #logo3d-wrapper {
    filter: drop-shadow(0 0 60px rgba(148, 252, 255, 0.08));
  }

  @media (prefers-reduced-motion: reduce) {
    #logo3d-shatter {
      display: none !important;
    }
    #logo3d-wrapper::after {
      content: '';
      position: absolute;
      inset: 10%;
      background: url('/outline_iconmark.png') center/contain no-repeat;
      filter: drop-shadow(0 0 30px rgba(148, 252, 255, 0.5))
              drop-shadow(0 0 60px rgba(148, 252, 255, 0.3));
    }
  }
</style>
