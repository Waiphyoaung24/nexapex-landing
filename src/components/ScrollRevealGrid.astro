          </div>
        </div>

        <!-- Layer 3: Center column top and bottom (2 images) -->
        <div class="reveal-layer">
          <div>
            <img src="https://images.unsplash.com/reserve/LJIZlzHgQ7WPSh5KVTCB_Typewriter.jpg?w=800&auto=format&fit=crop&q=60&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxzZWFyY2h8Mnx8aXRlbXxlbnwwfHwwfHx8MA%3D%3D" alt="" loading="lazy" />
          </div>
          <div>
            <img src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?w=800&auto=format&fit=crop&q=60&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxzZWFyY2h8Mnx8ZmFzaGlvbnxlbnwwfHwwfHx8MA%3D%3D" alt="" loading="lazy" />
          </div>
        </div>

        <!-- Center scaler image — starts fullscreen, shrinks on scroll -->
        <div class="reveal-scaler">
          <img src="https://assets.codepen.io/605876/model-shades.jpg?format=auto&quality=100" alt="" />
        </div>
      </div>
    </div>
  </section>
</div>

<style>
  .reveal-wrap {
    position: relative;
    z-index: 10;
    background: var(--bg, #0e1418);
    overflow: clip;
  }

  .reveal-section {
    min-height: 200vh;
  }

  .reveal-sticky {
    min-height: 100vh;
    width: 100vw;
    display: flex;
    place-items: center;
    align-content: center;
    position: sticky;
    top: 0;
    overflow: hidden;
  }

  .reveal-grid {
    --offset: 0;
    --container-width: 1400px;
    --gap: clamp(10px, 7.35vw, 80px);

    width: var(--container-width);
    max-width: calc(100% - 2rem);
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    grid-template-rows: repeat(3, auto);
    gap: var(--gap);
    margin: 0 auto;
    align-content: center;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  @media (max-width: 600px) {
    .reveal-grid {
      grid-template-columns: repeat(3, 1fr);
      --offset: -1;
    }

    .reveal-grid > .reveal-layer:nth-of-type(1) {
      display: none;
    }
  }

  /* Layers: overlay on full grid area with explicit column/row inheritance */
  .reveal-grid > .reveal-layer {
    display: grid;
    grid-column: 1 / -1;
    grid-row: 1 / -1;
    grid-template-columns: inherit;
    grid-template-rows: inherit;
    gap: inherit;
  }

  /* Layer 1: Outer edges */
  .reveal-grid > .reveal-layer:nth-of-type(1) div:nth-of-type(odd) {
    grid-column: 1;
  }
  .reveal-grid > .reveal-layer:nth-of-type(1) div:nth-of-type(even) {
    grid-column: -2;
  }

  /* Layer 2: Inner columns */
  .reveal-grid > .reveal-layer:nth-of-type(2) div:nth-of-type(odd) {
    grid-column: calc(2 + var(--offset));
  }
  .reveal-grid > .reveal-layer:nth-of-type(2) div:nth-of-type(even) {
    grid-column: calc(-3 - var(--offset));
  }

  /* Layer 3: Center top and bottom */
  .reveal-grid > .reveal-layer:nth-of-type(3) div:first-of-type {
    grid-column: calc(3 + var(--offset));
    grid-row: 1;
  }
  .reveal-grid > .reveal-layer:nth-of-type(3) div:last-of-type {
    grid-column: calc(3 + var(--offset));
    grid-row: -1;
  }

  .reveal-grid img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: 14px;
  }

  .reveal-grid .reveal-scaler {
    position: relative;
    grid-area: 2 / calc(3 + var(--offset));
    z-index: 2;
  }

  .reveal-scaler img {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    object-fit: cover;
    border-radius: 14px;
    width: 100%;
    height: 100%;
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    const image = document.querySelector('.reveal-scaler img') as HTMLImageElement;
    const section = document.getElementById('scroll-reveal-section');
    const layers = document.querySelectorAll('.reveal-grid > .reveal-layer');

    if (image && section && layers.length > 0) {
      const naturalWidth = image.offsetWidth;
      const naturalHeight = image.offsetHeight;
      const viewportWidth = window.innerWidth;
      const viewportHeight = window.innerHeight;

      // Scaler: fullscreen → natural grid cell size
      gsap.fromTo(image,
        { width: viewportWidth, height: viewportHeight },
        {
          width: naturalWidth,
          height: naturalHeight,
          ease: 'power2.inOut',
          scrollTrigger: {
            trigger: section,
            start: 'top top',
            end: '80% bottom',
            scrub: 2,
          },
        }
      );

      // Layer reveal: staggered fade + scale
      const easings = ['power1.inOut', 'power3.inOut', 'power4.inOut'];

      layers.forEach((layer, index) => {
        const end = `${100 - (index * 5)}% bottom`;

        // Fade in
        gsap.fromTo(layer,
          { opacity: 0 },
          {
            opacity: 1,
            ease: 'sine.out',
            scrollTrigger: {
              trigger: section,
              start: '55% bottom',
              end: end,
              scrub: 2,
            },
          }
        );

        // Scale up
        gsap.fromTo(layer,
          { scale: 0 },
          {
            scale: 1,
            ease: easings[index],
            scrollTrigger: {
              trigger: section,
              start: '30% bottom',
              end: end,
              scrub: 2,
            },
          }
        );
      });
    }
  }
</script>
