---
// ScrollRevealGrid.astro — Cinematic scroll-reveal image grid transition
// Center image starts fullscreen, shrinks on scroll to reveal a 5×3 mosaic
---

<div class="reveal-wrap">
  <section id="scroll-reveal-section" class="reveal-section">
    <div class="reveal-sticky">
      <div class="reveal-grid">
        <!-- Layer 1: Outer edges (6 images) — hidden on mobile -->
        <div class="reveal-layer">
          <div>
