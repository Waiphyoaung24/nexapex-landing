---
// Products -- horizontal scroll section with GSAP ScrollTrigger pin + scrub
// Each panel is 100vw wide. The heading panel leads, followed by full-bleed product cards.
const products = [
  {
    name: 'NexFactory',
    desc: 'AI-powered visual inspection for manufacturing quality control',
    image: '/product-factory-hero.jpg',
    align: 'left',
  },
  {
    name: 'NexHotel',
    desc: 'Dynamic pricing optimization for hospitality revenue',
    image: '/product-hotel-hero.jpg',
    align: 'right',
  },
  {
    name: 'NexPOS',
    desc: 'Retail customer intelligence and demand prediction',
    image: '/product-pos-hero.jpg',
    align: 'left',
  },
];

const PANEL_COUNT = products.length + 1; // +1 for heading panel
---

<section id="products" class="products-section relative z-20 overflow-hidden bg-bg">
  <!-- Horizontal scroll track -->
  <div class="products-track flex" style={`width: ${PANEL_COUNT * 100}vw;`}>

    <!-- Panel 0: Heading -->
    <div class="products-panel flex items-center justify-center w-screen h-screen shrink-0 px-6 md:px-14 lg:px-20">
      <div class="products-heading max-w-4xl">
        <span class="products-eyebrow block font-m text-[11px] text-cyan-dim uppercase tracking-[0.3em] mb-4 md:mb-6">
          What We Build
        </span>
        <h2 class="products-title font-d text-[clamp(2rem,7vw,7rem)] leading-[0.95] tracking-[-0.02em] text-overlay-display">
          Our Products
        </h2>
        <p class="products-subtitle font-b text-base md:text-xl text-dim mt-4 md:mt-6 max-w-xl leading-relaxed">
          Intelligence embedded where it matters most --
          factory floors, hotel lobbies, retail counters.
        </p>
        <div class="products-scroll-hint mt-8 md:mt-12 hidden md:flex items-center gap-3 text-cyan-dim/60">
          <span class="block w-8 h-px bg-current"></span>
          <span class="font-m text-[10px] uppercase tracking-[0.2em]">Scroll to explore</span>
          <span class="block w-8 h-px bg-current"></span>
        </div>
      </div>
    </div>

    <!-- Product cards -->
    {products.map((product, i) => (
      <div
        class="products-panel product-slide relative w-screen h-screen shrink-0 overflow-hidden flex items-center"
        data-product-index={i}
      >
        <div class:list={[
          'relative w-full max-w-[1400px] mx-auto px-6 md:px-12 lg:px-16 flex gap-8 md:gap-12 lg:gap-16 items-center',
          product.align === 'right' ? 'flex-row-reverse' : 'flex-row',
        ]}>
          <!-- Contained image -->
          <div class="relative w-[55%] shrink-0 hidden md:block">
            <div class="relative overflow-hidden rounded-2xl aspect-[4/3]">
              <img
                src={product.image}
                alt={`${product.name} -- ${product.desc}`}
                class="product-slide-img w-full h-full object-cover scale-[1.08]"
                loading="lazy"
              />
              <!-- Subtle vignette -->
              <div class="absolute inset-0 bg-gradient-to-t from-bg/40 via-transparent to-transparent pointer-events-none"></div>
            </div>
          </div>

          <!-- Text content -->
          <div class="product-slide-inner flex flex-col justify-center flex-1 py-8">
            <!-- Cyan accent line -->
            <div class="product-slide-accent w-px h-0 bg-cyan-dim/50 mb-5 origin-top"></div>

            <!-- Numbered index -->
            <span class="product-slide-num block font-m text-[10px] text-cyan-dim uppercase tracking-[0.3em] mb-3">
              {`0${i + 1}`}
            </span>

            <h3 class="product-slide-name font-d text-[clamp(1.8rem,3.5vw,3rem)] leading-[1] tracking-[-0.01em] text-white mb-3">
              {product.name}
            </h3>

            <p class="product-slide-desc font-b text-[0.9rem] md:text-base text-dim leading-relaxed max-w-sm mb-6">
              {product.desc}
            </p>

            <a
              href={`/#products`}
              class="product-slide-link group inline-flex items-center gap-2.5 w-max font-m text-[0.7rem] text-cyan-dim uppercase tracking-[0.18em] transition-colors duration-300 hover:text-cyan"
            >
              Learn More
              <span class="inline-block transition-transform duration-300 group-hover:translate-x-1">&rarr;</span>
            </a>
          </div>

          <!-- Mobile: image as background fallback -->
          <div class="absolute inset-0 md:hidden -z-10">
            <img
              src={product.image}
              alt=""
              class="product-slide-img w-full h-full object-cover opacity-30"
              loading="lazy"
              aria-hidden="true"
            />
            <div class="absolute inset-0 bg-bg/70"></div>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- Reduced-motion fallback: vertical stack -->
<noscript>
  <style>
    .products-track {
      flex-direction: column !important;
      width: 100% !important;
    }
    .products-panel {
      width: 100% !important;
      height: auto !important;
      min-height: 80vh;
    }
  </style>
</noscript>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const MOBILE_BREAKPOINT = 768;

  function initProductsScroll() {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isMobile = window.innerWidth < MOBILE_BREAKPOINT;
    const section = document.querySelector<HTMLElement>('#products');
    const track = document.querySelector<HTMLElement>('.products-track');
    const slides = gsap.utils.toArray<HTMLElement>('.product-slide');
    const headingPanel = document.querySelector<HTMLElement>('.products-heading');

    if (!section || !track) return;

    // ── Reduced motion or mobile: vertical stack, no horizontal scroll ──
    if (prefersReducedMotion || isMobile) {
      // CSS handles the vertical stacking via media query or reduced-motion rules.
      // Just ensure all elements are visible (GSAP initial states would hide them).
      gsap.set('.product-slide-num, .product-slide-name, .product-slide-desc, .product-slide-link', {
        opacity: 1,
        y: 0,
      });
      gsap.set('.product-slide-accent', { height: 40 });
      gsap.set('.product-slide-img', { xPercent: 0, scale: 1 });
      gsap.set('.products-eyebrow, .products-title, .products-subtitle, .products-scroll-hint', {
        opacity: 1,
        y: 0,
      });

      // On mobile, add simple scroll-triggered fade-up for each card
      if (isMobile && !prefersReducedMotion) {
        slides.forEach((slide) => {
          gsap.from(slide, {
            opacity: 0,
            y: 60,
            duration: 0.8,
            ease: 'power3.out',
            scrollTrigger: {
              trigger: slide,
              start: 'top 85%',
              toggleActions: 'play none none none',
            },
          });
        });
      }
      return;
    }

    // ── Desktop: Horizontal scroll tween ──
    const scrollTween = gsap.to(track, {
      x: () => -(track.scrollWidth - window.innerWidth),
      ease: 'none',
      scrollTrigger: {
        trigger: section,
        pin: true,
        scrub: 1,
        end: () => `+=${track.scrollWidth - window.innerWidth}`,
        invalidateOnRefresh: true,
      },
    });

    // ── Heading panel entrance ──
    if (headingPanel) {
      const eyebrow = headingPanel.querySelector('.products-eyebrow');
      const title = headingPanel.querySelector('.products-title');
      const subtitle = headingPanel.querySelector('.products-subtitle');
      const hint = headingPanel.querySelector('.products-scroll-hint');

      gsap.set([eyebrow, title, subtitle, hint], { opacity: 0, y: 30 });

      const headingTl = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: 'top 80%',
          end: 'top 20%',
          scrub: false,
          once: true,
        },
      });

      headingTl
        .to(eyebrow, { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' }, 0)
        .to(title, { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' }, 0.1)
        .to(subtitle, { opacity: 1, y: 0, duration: 0.7, ease: 'power3.out' }, 0.25)
        .to(hint, { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' }, 0.4);
    }

    // ── Per-card entrance animations via containerAnimation ──
    slides.forEach((slide) => {
      const accent = slide.querySelector('.product-slide-accent');
      const num = slide.querySelector('.product-slide-num');
      const slideName = slide.querySelector('.product-slide-name');
      const desc = slide.querySelector('.product-slide-desc');
      const link = slide.querySelector('.product-slide-link');
      const img = slide.querySelector('.product-slide-img');

      // Image parallax (subtle horizontal shift)
      if (img) {
        gsap.fromTo(img,
          { xPercent: -5, scale: 1.1 },
          {
            xPercent: 5,
            scale: 1,
            ease: 'none',
            scrollTrigger: {
              trigger: slide,
              containerAnimation: scrollTween,
              start: 'left right',
              end: 'right left',
              scrub: true,
            },
          },
        );
      }

      // Card content staggered reveal
      const cardTl = gsap.timeline({
        scrollTrigger: {
          trigger: slide,
          containerAnimation: scrollTween,
          start: 'left 75%',
          end: 'left 35%',
          scrub: true,
        },
      });

      // Accent line draws down
      if (accent) {
        cardTl.fromTo(accent,
          { height: 0 },
          { height: 60, ease: 'none' },
          0,
        );
      }

      // Number fades in
      if (num) {
        cardTl.fromTo(num,
          { opacity: 0, y: 20 },
          { opacity: 1, y: 0, ease: 'none' },
          0,
        );
      }

      // Name slides up
      if (slideName) {
        cardTl.fromTo(slideName,
          { opacity: 0, y: 40 },
          { opacity: 1, y: 0, ease: 'none' },
          0.05,
        );
      }

      // Description fades in
      if (desc) {
        cardTl.fromTo(desc,
          { opacity: 0, y: 30 },
          { opacity: 1, y: 0, ease: 'none' },
          0.15,
        );
      }

      // Link fades in
      if (link) {
        cardTl.fromTo(link,
          { opacity: 0, y: 20 },
          { opacity: 1, y: 0, ease: 'none' },
          0.25,
        );
      }
    });
  }

  // Initialize after DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initProductsScroll);
  } else {
    initProductsScroll();
  }
</script>
