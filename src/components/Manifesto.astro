---
// Manifesto — pinned section with word-by-word illuminate on scroll
---

<section id="manifesto" class="relative z-20 w-full h-[200vh] bg-bg">
  <div class="sticky top-0 h-screen flex items-center justify-center px-6 md:px-10 lg:px-14">
    <!-- Ambient glow for depth -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] rounded-full opacity-20 blur-3xl pointer-events-none" style="background: radial-gradient(ellipse, rgba(148,252,255,0.12) 0%, transparent 70%);"></div>
    <p id="manifesto-text" class="relative font-d text-center text-[clamp(1.8rem,4vw,3.5rem)] leading-[1.25] tracking-[-0.01em] max-w-[900px]">
    </p>
  </div>
  <!-- Gradient bridge → Capabilities -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-b from-transparent to-bg pointer-events-none"></div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Build word spans
  const container = document.getElementById('manifesto-text');
  const sentence = 'We build AI systems that see, predict, and understand — engineered for the real world of Southeast Asia.';
  const words = sentence.split(' ');

  words.forEach((word) => {
    const span = document.createElement('span');
    span.className = 'manifesto-word inline-block mr-[0.3em]';
    span.textContent = word;
    // "AI" gets cyan color when illuminated
    if (word === 'AI') span.dataset.accent = 'true';
    container?.appendChild(span);
  });

  const wordEls = document.querySelectorAll('.manifesto-word');

  if (prefersReducedMotion) {
    wordEls.forEach((w) => {
      const el = w as HTMLElement;
      el.style.color = el.dataset.accent ? '#5ac8cb' : '#f0f1ef';
    });
  } else {
    // Set initial dim state
    gsap.set(wordEls, { color: 'rgba(240, 241, 239, 0.12)' });

    // Illuminate words one by one on scroll
    wordEls.forEach((word, i) => {
      const el = word as HTMLElement;
      const targetColor = el.dataset.accent ? '#5ac8cb' : '#f0f1ef';

      gsap.to(word, {
        color: targetColor,
        ease: 'none',
        scrollTrigger: {
          trigger: '#manifesto',
          start: () => `top+=${(i / words.length) * window.innerHeight * 1.2} top`,
          end: () => `top+=${((i + 1) / words.length) * window.innerHeight * 1.2} top`,
          scrub: 1,
        },
      });
    });
  }
</script>
