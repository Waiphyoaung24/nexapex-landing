---
// Capabilities — cinematic 3D section with scroll-driven camera + text overlays
import CapabilitiesCanvas from './three/CapabilitiesCanvas';

const capabilities = [
  {
    num: '01',
    title: 'Computer Vision',
    desc: 'Quality control that never blinks',
    position: 'left' as const,
  },
  {
    num: '02',
    title: 'Predictive Intelligence',
    desc: 'Demand forecasting that learns your market',
    position: 'right' as const,
  },
  {
    num: '03',
    title: 'Autonomous Systems',
    desc: 'Self-optimizing operations that run 24/7',
    position: 'left' as const,
  },
  {
    num: '04',
    title: 'Natural Language',
    desc: "Systems that speak your customers' language",
    position: 'right' as const,
  },
  {
    num: '05',
    title: 'Edge AI',
    desc: 'On-device intelligence for real-time decisions',
    position: 'center' as const,
  },
  {
    num: '06',
    title: 'AI Infrastructure',
    desc: 'Scalable pipelines from prototype to production',
    position: 'center' as const,
  },
];
---

<!-- Fixed 3D canvas — renders behind everything, fades in/out via GSAP -->
<CapabilitiesCanvas client:only="react" />

<!-- Scroll container — height drives the camera animation -->
<section id="capabilities-scroll" class="relative z-10" style="height: 400vh;">
  {capabilities.map((cap, i) => (
    <div
      class:list={[
        'cap-overlay sticky top-0 h-screen flex items-center pointer-events-none',
        'px-6 md:px-10 lg:px-14',
        cap.position === 'right' ? 'justify-end' : cap.position === 'center' ? 'justify-center' : 'justify-start',
      ]}
      data-cap-index={i}
    >
      <div
        class:list={[
          'max-w-lg',
          cap.position === 'right' ? 'text-right' : cap.position === 'center' ? 'text-center' : 'text-left',
        ]}
      >
        <!-- Large faint number -->
        <span class="cap-num block font-d text-[clamp(5rem,12vw,10rem)] leading-none text-cyan-dim/[0.08] select-none">
          {cap.num}
        </span>

        <!-- Title -->
        <h3 class="cap-title font-d text-[clamp(1.8rem,4.5vw,3.5rem)] text-white leading-[0.95] tracking-[-0.02em] -mt-8 md:-mt-12 drop-shadow-[0_2px_20px_rgba(0,0,0,0.8)]">
          {cap.title}
        </h3>

        <!-- Description -->
        <p class="cap-desc font-b text-base md:text-lg text-dim mt-3 md:mt-4 leading-relaxed drop-shadow-[0_2px_10px_rgba(0,0,0,0.8)]">
          {cap.desc}
        </p>
      </div>
    </div>
  ))}
</section>

<!-- GSAP text overlay animations -->
<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const overlays = document.querySelectorAll('.cap-overlay');

  if (prefersReducedMotion) {
    overlays.forEach((o) => {
      gsap.set(o.querySelectorAll('.cap-num, .cap-title, .cap-desc'), { opacity: 1 });
    });
  } else {
    overlays.forEach((overlay, i) => {
      const num = overlay.querySelector('.cap-num');
      const title = overlay.querySelector('.cap-title');
      const desc = overlay.querySelector('.cap-desc');
      const total = overlays.length;

      // Each capability gets 1/total of the scroll range
      const segmentStart = (i / total) * 100;
      const segmentEnd = ((i + 1) / total) * 100;
      const midPoint = segmentStart + (segmentEnd - segmentStart) * 0.5;

      // Fade in
      gsap.fromTo([num, title, desc],
        { x: i === 0 ? 0 : -60, opacity: i === 0 ? 1 : 0 },
        {
          x: 0,
          opacity: 1,
          stagger: 0.05,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: '#capabilities-scroll',
            start: `${segmentStart}% top`,
            end: `${segmentStart + 8}% top`,
            scrub: 0.5,
          },
        }
      );

      // Fade out (except last — let section fade handle it)
      if (i < total - 1) {
        gsap.to([num, title, desc], {
          x: 60,
          opacity: 0,
          stagger: -0.03,
          ease: 'power2.in',
          scrollTrigger: {
            trigger: '#capabilities-scroll',
            start: `${midPoint + 10}% top`,
            end: `${segmentEnd - 2}% top`,
            scrub: 0.5,
          },
        });
      }
    });
  }
</script>
