---
// ScrollGrid — scroll-driven image grid with staggered layer reveals
// Center image shrinks from fullscreen; layers scale + fade in around it
// Adapted from jhey's scroll grid, converted from Motion to GSAP ScrollTrigger
---

<section class="sg-wrap" id="scroll-grid">
  <div class="sg-sticky">
    <div class="sg-grid">
      <!-- Layer 1: Outer edges (6 images) -->
      <div class="sg-layer">
        <div><img src="https://images.unsplash.com/photo-1463100099107-aa0980c362e6?w=600&auto=format&fit=crop&q=60" alt="Engineering workspace" loading="lazy" /></div>
        <div><img src="https://images.unsplash.com/photo-1556304044-0699e31c6a34?w=600&auto=format&fit=crop&q=60" alt="Precision manufacturing" loading="lazy" /></div>
        <div><img src="https://images.unsplash.com/photo-1590330297626-d7aff25a0431?w=600&auto=format&fit=crop&q=60" alt="Advanced materials" loading="lazy" /></div>
        <div><img src="https://images.unsplash.com/photo-1487222477894-8943e31ef7b2?w=600&auto=format&fit=crop&q=60" alt="Research and development" loading="lazy" /></div>
        <div><img src="https://images.unsplash.com/photo-1488161628813-04466f872be2?w=600&auto=format&fit=crop&q=60" alt="Innovation lab" loading="lazy" /></div>
        <div><img src="https://images.unsplash.com/photo-1565321590372-09331b9dd1eb?w=600&auto=format&fit=crop&q=60" alt="Product design" loading="lazy" /></div>
      </div>
      <!-- Layer 2: Inner columns (6 images) -->
      <div class="sg-layer">
        <div><img src="https://images.unsplash.com/photo-1531525645387-7f14be1bdbbd?w=600&auto=format&fit=crop&q=60" alt="Technology hardware" loading="lazy" /></div>
        <div><img src="https://images.unsplash.com/photo-1637414165749-9b3cd88b8271?w=600&auto=format&fit=crop&q=60" alt="Smart devices" loading="lazy" /></div>
        <div><img src="https://images.unsplash.com/photo-1699911251220-8e0de3b5ce88?w=600&auto=format&fit=crop&q=60" alt="Autonomous systems" loading="lazy" /></div>
        <div><img src="https://images.unsplash.com/photo-1667483629944-6414ad0648c5?w=600&auto=format&fit=crop&q=60" alt="Precision instruments" loading="lazy" /></div>
        <div><img src="https://plus.unsplash.com/premium_photo-1706078438060-d76ced26d8d5?w=600&auto=format&fit=crop&q=60" alt="Visual computing" loading="lazy" /></div>
        <div><img src="https://images.unsplash.com/photo-1525385444278-b7968e7e28dc?w=600&auto=format&fit=crop&q=60" alt="Industrial equipment" loading="lazy" /></div>
      </div>
      <!-- Layer 3: Center column top and bottom (2 images) -->
      <div class="sg-layer">
        <div><img src="https://images.unsplash.com/reserve/LJIZlzHgQ7WPSh5KVTCB_Typewriter.jpg?w=600&auto=format&fit=crop&q=60" alt="Engineering tools" loading="lazy" /></div>
        <div><img src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?w=600&auto=format&fit=crop&q=60" alt="Quality inspection" loading="lazy" /></div>
      </div>
      <!-- Center scaler image -->
      <div class="sg-scaler">
        <img src="https://images.unsplash.com/photo-1620712943543-bcc4688e7485?w=800&auto=format&fit=crop&q=80" alt="Artificial intelligence" />
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion && window.innerWidth > 768) {
    const image = document.querySelector<HTMLImageElement>('.sg-scaler img');
    const section = document.querySelector<HTMLElement>('.sg-wrap');
    const layers = document.querySelectorAll<HTMLElement>('.sg-layer');

    if (image && section && layers.length > 0) {
      // Wait for image to load before measuring natural size
      const initScaler = () => {
        const naturalWidth = image.offsetWidth;
        const naturalHeight = image.offsetHeight;

        // Guard: skip if dimensions are 0 (image not rendered yet)
        if (naturalWidth < 10 || naturalHeight < 10) return;

        const vw = window.innerWidth;
        const vh = window.innerHeight;

        gsap.fromTo(image,
          { width: vw, height: vh },
          {
            width: naturalWidth,
            height: naturalHeight,
            ease: 'power2.inOut',
            scrollTrigger: {
              trigger: section,
              start: 'top top',
              end: '80% bottom',
              scrub: true,
              invalidateOnRefresh: true,
            },
          }
        );
      };

      if (image.complete && image.naturalWidth > 0) {
        initScaler();
      } else {
        image.addEventListener('load', initScaler);
      }

      // Each layer: fade in + scale up with staggered timing
      const scaleEasings = ['power1.inOut', 'power3.inOut', 'power4.inOut'];

      layers.forEach((layer, i) => {
        const endPercent = (1 - i * 0.05) * 100;

        gsap.set(layer, { opacity: 0, scale: 0 });

        const tl = gsap.timeline({
          scrollTrigger: {
            trigger: section,
            start: 'top top',
            end: `${endPercent}% bottom`,
            scrub: true,
          },
        });

        // Opacity: hold at 0 until 55% scroll, then fade to 1
        tl.to(layer, { opacity: 1, duration: 0.45, ease: 'sine.out' }, 0.55);
        // Scale: hold at 0 until 30% scroll, then scale to 1
        tl.to(layer, { scale: 1, duration: 0.7, ease: scaleEasings[i] }, 0.3);
      });
    }
  }
</script>
