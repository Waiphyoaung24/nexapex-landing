---
// FooterCTA — Contact section + Footer bar
// Lusion-inspired layout: 3-column contact grid + minimal footer strip
---

<!-- Contact Section -->
<section id="contact" class="contact-section relative z-20 bg-bg">
  <div class="max-w-[1440px] mx-auto px-6 md:px-10 lg:px-14 py-24 md:py-32 lg:py-40">

    <!-- Section eyebrow -->
    <div class="contact-eyebrow mb-16 md:mb-24">
      <div class="w-[50px] h-px bg-cyan-dim mb-6"></div>
      <p class="font-m text-[0.6rem] uppercase tracking-[0.25em] text-cyan-dim">Contact</p>
    </div>

    <!-- 3-column grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-16 md:gap-8 lg:gap-12">

      <!-- Column 1: Location -->
      <div class="contact-col">
        <h3 class="font-d text-white text-[clamp(1.4rem,2.5vw,1.8rem)] leading-[1.15] tracking-[0.02em] mb-8">
          NexApex<br/>AI Lab
        </h3>
        <div class="space-y-1.5">
          <p class="font-b text-[0.82rem] text-dim leading-relaxed">Yangon, Myanmar</p>
          <p class="font-b text-[0.82rem] text-dim leading-relaxed">Southeast Asia</p>
        </div>
      </div>

      <!-- Column 2: Links + Emails -->
      <div class="contact-col">
        <!-- Social links -->
        <div class="mb-10">
          <nav class="flex flex-col gap-3" aria-label="Social links">
            <a href="https://x.com/nexapex" target="_blank" rel="noopener noreferrer" class="contact-link font-b text-[0.82rem] text-text transition-colors duration-300 hover:text-cyan-dim cursor-pointer">
              Twitter / X
            </a>
            <a href="https://linkedin.com/company/nexapex" target="_blank" rel="noopener noreferrer" class="contact-link font-b text-[0.82rem] text-text transition-colors duration-300 hover:text-cyan-dim cursor-pointer">
              LinkedIn
            </a>
            <a href="https://github.com/nexapex" target="_blank" rel="noopener noreferrer" class="contact-link font-b text-[0.82rem] text-text transition-colors duration-300 hover:text-cyan-dim cursor-pointer">
              GitHub
            </a>
          </nav>
        </div>

        <!-- Email addresses -->
        <div class="space-y-6">
          <div>
            <p class="font-m text-[0.58rem] uppercase tracking-[0.25em] text-dim mb-2">General enquiries</p>
            <a href="mailto:hello@nexapex.com" class="contact-link font-b text-[0.82rem] text-text transition-colors duration-300 hover:text-cyan-dim cursor-pointer">
              hello@nexapex.com
            </a>
          </div>
          <div>
            <p class="font-m text-[0.58rem] uppercase tracking-[0.25em] text-dim mb-2">New business</p>
            <a href="mailto:business@nexapex.com" class="contact-link font-b text-[0.82rem] text-text transition-colors duration-300 hover:text-cyan-dim cursor-pointer">
              business@nexapex.com
            </a>
          </div>
        </div>
      </div>

      <!-- Column 3: Newsletter -->
      <div class="contact-col">
        <h3 class="font-d text-white text-[clamp(1.4rem,2.5vw,1.8rem)] leading-[1.15] tracking-[0.02em] mb-8">
          Subscribe to<br/>our newsletter
        </h3>
        <form id="newsletter-form" action="#" class="newsletter-form" aria-label="Newsletter subscription">
          <div class="relative flex items-center border-b border-dim/40 pb-2 transition-colors duration-300 focus-within:border-cyan-dim/60">
            <label for="newsletter-email" class="sr-only">Email address</label>
            <input
              id="newsletter-email"
              type="email"
              name="email"
              placeholder="your@email.com"
              required
              autocomplete="email"
              class="flex-1 bg-transparent font-b text-[0.82rem] text-text placeholder:text-dim/60 outline-none"
            />
            <button
              type="submit"
              aria-label="Subscribe to newsletter"
              class="newsletter-submit ml-4 w-10 h-10 rounded-full border border-cyan-dim/40 flex items-center justify-center text-cyan-dim transition-all duration-300 hover:bg-cyan-dim hover:text-bg cursor-pointer shrink-0"
            >
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3.5 8H12.5M12.5 8L8.5 4M12.5 8L8.5 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
          <p id="newsletter-feedback" class="font-m text-[0.65rem] mt-3 h-4 text-cyan-dim opacity-0 transition-opacity duration-300" aria-live="polite"></p>
        </form>
      </div>

    </div>
  </div>
</section>

<!-- Footer Bar -->
<footer class="footer-bar relative z-20 bg-bg border-t border-surface2/60">
  <div class="max-w-[1440px] mx-auto px-6 md:px-10 lg:px-14 py-6 flex flex-col md:flex-row items-center justify-between gap-4">

    <p id="footer-copy" class="font-m text-[0.72rem] text-dim tracking-[0.02em] opacity-0">
      &copy; 2026 NexApex AI Lab
    </p>

    <p id="footer-lab" class="font-m text-[0.72rem] text-dim tracking-[0.02em] opacity-0">
      R&amp;D: <a href="https://labs.nexapex.com" target="_blank" rel="noopener noreferrer" class="text-text transition-colors duration-300 hover:text-cyan-dim cursor-pointer">labs.nexapex.com</a>
    </p>

    <button
      id="back-to-top"
      aria-label="Back to top"
      class="w-10 h-10 rounded-full border border-dim/30 flex items-center justify-center text-dim transition-all duration-300 hover:border-cyan-dim/60 hover:text-cyan-dim cursor-pointer opacity-0"
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M8 12.5V3.5M8 3.5L4 7.5M8 3.5L12 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

  </div>
</footer>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const footerCopy = document.getElementById('footer-copy');
  const footerLab = document.getElementById('footer-lab');
  const backToTop = document.getElementById('back-to-top');

  if (prefersReducedMotion) {
    gsap.set([footerCopy, footerLab, backToTop], { opacity: 1 });
    gsap.set('.contact-eyebrow, .contact-col', { opacity: 1, y: 0 });
  } else {
    /* ── Contact section reveal ── */
    gsap.set('.contact-eyebrow', { opacity: 0, y: 24 });
    gsap.set('.contact-col', { opacity: 0, y: 32 });

    gsap.to('.contact-eyebrow', {
      opacity: 1,
      y: 0,
      duration: 0.8,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: '#contact',
        start: 'top 80%',
        toggleActions: 'play none none none',
      },
    });

    gsap.to('.contact-col', {
      opacity: 1,
      y: 0,
      duration: 0.8,
      stagger: 0.15,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: '#contact',
        start: 'top 70%',
        toggleActions: 'play none none none',
      },
    });

    /* ── Footer bar fade-in ── */
    gsap.to([footerCopy, footerLab, backToTop], {
      opacity: 1,
      stagger: 0.1,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: '.footer-bar',
        start: 'top 90%',
        end: 'top 60%',
        scrub: 1,
      },
    });
  }

  /* ── Back to top ── */
  backToTop?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  /* ── Newsletter form (visual only) ── */
  const newsletterForm = document.getElementById('newsletter-form') as HTMLFormElement | null;
  const feedback = document.getElementById('newsletter-feedback');

  newsletterForm?.addEventListener('submit', (e: Event) => {
    e.preventDefault();
    const emailInput = newsletterForm.querySelector('input[type="email"]') as HTMLInputElement;

    if (emailInput && emailInput.value && feedback) {
      feedback.textContent = 'Subscribed. Welcome aboard.';
      feedback.style.opacity = '1';
      emailInput.value = '';

      setTimeout(() => {
        feedback.style.opacity = '0';
      }, 3000);
    }
  });
</script>
