---
// FooterCTA — Contact section + Footer bar
// Lusion-inspired layout: 3-column contact grid + minimal footer strip
// GSAP-driven entrance + interactive hover effects
---

<!-- Contact Section -->
<section id="contact" class="contact-section relative z-20 bg-bg">
  <div class="max-w-[1440px] mx-auto px-5 md:px-10 lg:px-14 py-16 md:py-32 lg:py-40">

    <!-- Section eyebrow -->
    <div class="contact-eyebrow mb-10 md:mb-24">
      <div class="contact-eyebrow-line w-[50px] h-px bg-cyan-dim mb-4 md:mb-6 origin-left scale-x-0"></div>
      <p class="font-m text-[0.6rem] uppercase tracking-[0.25em] text-cyan-dim">Contact</p>
    </div>

    <!-- 3-column grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8 lg:gap-12">

      <!-- Column 1: Location -->
      <div class="contact-col">
        <h3 class="font-d text-white text-[clamp(1.3rem,2.8vw,2.2rem)] leading-[1.1] tracking-[0.02em] mb-6 md:mb-8">
          NexApex<br/>AI Lab
        </h3>
        <div class="space-y-1.5">
          <p class="font-b text-[0.85rem] text-text leading-relaxed">Bangkok, Thailand</p>
          <p class="font-b text-[0.85rem] text-dim leading-relaxed">Southeast Asia</p>
        </div>
      </div>

      <!-- Column 2: Links + Emails -->
      <div class="contact-col">
        <!-- Social links -->
        <div class="mb-10">
          <nav class="flex flex-col gap-3" aria-label="Social links">
            <a href="https://x.com/nexapex" target="_blank" rel="noopener noreferrer" class="contact-link inline-flex items-center gap-2 font-b text-[0.85rem] text-text transition-colors duration-300 hover:text-cyan-dim cursor-pointer w-max">
              <span class="contact-link-arrow inline-block opacity-0 -translate-x-2 transition-all duration-300">&rarr;</span>
              Twitter / X
            </a>
            <a href="https://linkedin.com/company/nexapex" target="_blank" rel="noopener noreferrer" class="contact-link inline-flex items-center gap-2 font-b text-[0.85rem] text-text transition-colors duration-300 hover:text-cyan-dim cursor-pointer w-max">
              <span class="contact-link-arrow inline-block opacity-0 -translate-x-2 transition-all duration-300">&rarr;</span>
              LinkedIn
            </a>
            <a href="https://github.com/nexapex" target="_blank" rel="noopener noreferrer" class="contact-link inline-flex items-center gap-2 font-b text-[0.85rem] text-text transition-colors duration-300 hover:text-cyan-dim cursor-pointer w-max">
              <span class="contact-link-arrow inline-block opacity-0 -translate-x-2 transition-all duration-300">&rarr;</span>
              GitHub
            </a>
          </nav>
        </div>

        <!-- Email addresses -->
        <div class="space-y-6">
          <div>
            <p class="font-m text-[0.6rem] uppercase tracking-[0.25em] text-dim mb-2">General enquiries</p>
            <a href="mailto:hello@nexapex.com" class="contact-link inline-flex items-center gap-2 font-b text-[0.85rem] text-white font-medium transition-colors duration-300 hover:text-cyan-dim cursor-pointer w-max">
              <span class="contact-link-arrow inline-block opacity-0 -translate-x-2 transition-all duration-300">&rarr;</span>
              hello@nexapex.com
            </a>
          </div>
          <div>
            <p class="font-m text-[0.6rem] uppercase tracking-[0.25em] text-dim mb-2">New business</p>
            <a href="mailto:business@nexapex.com" class="contact-link inline-flex items-center gap-2 font-b text-[0.85rem] text-white font-medium transition-colors duration-300 hover:text-cyan-dim cursor-pointer w-max">
              <span class="contact-link-arrow inline-block opacity-0 -translate-x-2 transition-all duration-300">&rarr;</span>
              business@nexapex.com
            </a>
          </div>
        </div>
      </div>

      <!-- Column 3: Newsletter -->
      <div class="contact-col">
        <h3 class="font-d text-white text-[clamp(1.3rem,2.8vw,2.2rem)] leading-[1.1] tracking-[0.02em] mb-6 md:mb-8">
          Subscribe to<br/>our newsletter
        </h3>
        <form id="newsletter-form" action="#" class="newsletter-form" aria-label="Newsletter subscription">
          <div class="newsletter-input-wrap relative flex items-center border-b border-dim/40 pb-2 transition-all duration-500 focus-within:border-cyan-dim/60">
            <label for="newsletter-email" class="sr-only">Email address</label>
            <input
              id="newsletter-email"
              type="email"
              name="email"
              placeholder="your@email.com"
              required
              autocomplete="email"
              class="flex-1 bg-transparent font-b text-[0.85rem] text-white placeholder:text-dim/50 outline-none"
            />
            <button
              type="submit"
              aria-label="Subscribe to newsletter"
              class="newsletter-submit ml-4 w-10 h-10 rounded-full border border-cyan-dim/40 flex items-center justify-center text-cyan-dim transition-all duration-300 hover:bg-cyan-dim hover:text-bg hover:scale-110 cursor-pointer shrink-0"
            >
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3.5 8H12.5M12.5 8L8.5 4M12.5 8L8.5 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
          <p id="newsletter-feedback" class="font-m text-[0.65rem] mt-3 h-4 text-cyan-dim opacity-0 transition-opacity duration-300" aria-live="polite"></p>
        </form>
      </div>

    </div>
  </div>
</section>

<!-- Footer Bar -->
<footer class="footer-bar relative z-20 bg-bg border-t border-surface2/60">
  <div class="max-w-[1440px] mx-auto px-6 md:px-10 lg:px-14 py-6 flex flex-col md:flex-row items-center justify-between gap-4">

    <p id="footer-copy" class="font-m text-[0.72rem] text-dim tracking-[0.02em] opacity-0">
      &copy; 2026 NexApex AI Lab
    </p>

    <p id="footer-lab" class="font-m text-[0.72rem] text-dim tracking-[0.02em] opacity-0">
      R&amp;D: <a href="https://labs.nexapex.com" target="_blank" rel="noopener noreferrer" class="text-text transition-colors duration-300 hover:text-cyan-dim cursor-pointer">labs.nexapex.com</a>
    </p>

    <button
      id="back-to-top"
      aria-label="Back to top"
      class="w-10 h-10 rounded-full border border-dim/30 flex items-center justify-center text-dim transition-all duration-300 hover:border-cyan-dim/60 hover:text-cyan-dim hover:scale-110 cursor-pointer opacity-0"
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M8 12.5V3.5M8 3.5L4 7.5M8 3.5L12 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

  </div>
</footer>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const footerCopy = document.getElementById('footer-copy');
  const footerLab = document.getElementById('footer-lab');
  const backToTop = document.getElementById('back-to-top');

  if (prefersReducedMotion) {
    gsap.set([footerCopy, footerLab, backToTop], { opacity: 1 });
    gsap.set('.contact-eyebrow, .contact-col', { opacity: 1, y: 0 });
    gsap.set('.contact-eyebrow-line', { scaleX: 1 });
  } else {
    /* ── Contact eyebrow: line draws then text fades ── */
    gsap.set('.contact-eyebrow', { opacity: 0, y: 24 });
    gsap.set('.contact-col', { opacity: 0, y: 40 });

    const eyebrowTl = gsap.timeline({
      scrollTrigger: {
        trigger: '#contact',
        start: 'top 80%',
        toggleActions: 'play none none none',
      },
    });

    eyebrowTl
      .to('.contact-eyebrow', { opacity: 1, y: 0, duration: 0.6, ease: 'power3.out' })
      .to('.contact-eyebrow-line', { scaleX: 1, duration: 0.8, ease: 'power2.out' }, '-=0.3');

    /* ── Columns stagger in ── */
    gsap.to('.contact-col', {
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.2,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: '#contact',
        start: 'top 65%',
        toggleActions: 'play none none none',
      },
    });

    /* ── Interactive hover: arrows slide in on link hover ── */
    document.querySelectorAll('.contact-link').forEach((link) => {
      const arrow = link.querySelector('.contact-link-arrow') as HTMLElement;
      if (!arrow) return;

      link.addEventListener('mouseenter', () => {
        gsap.to(arrow, { opacity: 1, x: 0, duration: 0.25, ease: 'power2.out' });
      });
      link.addEventListener('mouseleave', () => {
        gsap.to(arrow, { opacity: 0, x: -8, duration: 0.2, ease: 'power2.in' });
      });
    });

    /* ── Newsletter input: glow pulse on focus ── */
    const inputWrap = document.querySelector('.newsletter-input-wrap');
    const emailInput = document.getElementById('newsletter-email');

    if (inputWrap && emailInput) {
      emailInput.addEventListener('focus', () => {
        gsap.to(inputWrap, {
          boxShadow: '0 2px 20px rgba(148, 252, 255, 0.08)',
          duration: 0.4,
          ease: 'power2.out',
        });
      });
      emailInput.addEventListener('blur', () => {
        gsap.to(inputWrap, {
          boxShadow: '0 0 0 transparent',
          duration: 0.3,
          ease: 'power2.in',
        });
      });
    }

    /* ── Footer bar fade-in ── */
    gsap.to([footerCopy, footerLab, backToTop], {
      opacity: 1,
      stagger: 0.1,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: '.footer-bar',
        start: 'top 90%',
        end: 'top 60%',
        scrub: 1,
      },
    });
  }

  /* ── Back to top ── */
  backToTop?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  /* ── Newsletter form (visual only) ── */
  const newsletterForm = document.getElementById('newsletter-form') as HTMLFormElement | null;
  const feedback = document.getElementById('newsletter-feedback');

  newsletterForm?.addEventListener('submit', (e: Event) => {
    e.preventDefault();
    const emailInput = newsletterForm.querySelector('input[type="email"]') as HTMLInputElement;
    const submitBtn = newsletterForm.querySelector('.newsletter-submit') as HTMLElement;

    if (emailInput && emailInput.value && feedback) {
      // Success animation
      if (submitBtn) {
        gsap.to(submitBtn, {
          scale: 1.2,
          duration: 0.15,
          yoyo: true,
          repeat: 1,
          ease: 'power2.out',
        });
      }

      feedback.textContent = 'Subscribed. Welcome aboard.';
      gsap.to(feedback, { opacity: 1, duration: 0.3 });
      emailInput.value = '';

      gsap.to(feedback, { opacity: 0, duration: 0.3, delay: 3 });
    }
  });
</script>
