---
const navItems = [
  { label: 'Solutions', href: '/#services' },
  { label: 'Process', href: '/#process' },
  { label: 'Products', href: '/#work' },
  { label: 'About', href: '/#about' },
];
---

<nav id="main-nav" class="fixed top-4 left-4 right-4 z-[100] bg-bg/50 backdrop-blur-[20px] backdrop-saturate-[1.3] border border-white/[0.04] rounded-2xl shadow-[0_4px_24px_rgba(0,0,0,0.4),inset_0_1px_0_rgba(255,255,255,0.03)] transition-[background-color,border-color,box-shadow] duration-500" style="transition-timing-function: cubic-bezier(0.32, 0.72, 0, 1);">
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[200] focus:bg-bg focus:text-cyan focus:px-4 focus:py-2 focus:rounded font-m text-sm">Skip to content</a>
  <div class="max-w-[1400px] mx-auto px-6 md:px-10 flex items-center justify-between h-14">

    <!-- Logo -->
    <a href="/" class="group relative flex items-center cursor-pointer no-underline">
      <div class="relative h-10 w-10 transition-[filter] duration-500 group-hover:drop-shadow-[0_0_16px_rgba(148,252,255,0.25)]" style="transition-timing-function: cubic-bezier(0.32, 0.72, 0, 1);">
        <img
          src="/full_color_logo.svg"
          alt="NexApex Logo"
          width="40"
          height="40"
          class="object-contain w-full h-full"
        />
      </div>
      <span class="font-d text-[11px] tracking-[3px] uppercase text-sage/70 ml-5 hidden sm:block transition-colors duration-300 group-hover:text-cyan" style="transition-timing-function: cubic-bezier(0.32, 0.72, 0, 1);">
        NexApex
      </span>
    </a>

    <!-- Desktop navigation -->
    <ul class="hidden md:flex gap-7 list-none m-0 p-0 items-center">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="text-dim no-underline font-m text-[11px] font-medium tracking-[1.5px] uppercase relative py-1 cursor-pointer hover:text-cyan-dim after:content-[''] after:absolute after:bottom-0 after:left-0 after:w-0 after:h-px after:bg-cyan-dim after:rounded-full focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-cyan/50 focus-visible:rounded transition-colors duration-300 hover:after:w-full after:transition-[width] after:duration-500"
            style="transition-timing-function: cubic-bezier(0.32, 0.72, 0, 1); --tw-after-transition-timing-function: cubic-bezier(0.32, 0.72, 0, 1);"
          >
            {item.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="/#contact"
          class="font-m text-[11px] font-medium tracking-[1.5px] uppercase px-5 py-[7px] border border-cyan/25 text-cyan no-underline cursor-pointer rounded-full hover:bg-cyan/[0.07] hover:border-cyan/50 hover:shadow-[0_0_16px_rgba(148,252,255,0.1)] focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-cyan/50 focus-visible:rounded-full active:scale-[0.97] transition-[color,background-color,border-color,box-shadow,transform] duration-300"
          style="transition-timing-function: cubic-bezier(0.32, 0.72, 0, 1);"
        >
          Let's Talk
        </a>
      </li>
    </ul>

    <!-- Hamburger button — mobile only -->
    <button
      id="hamburger-btn"
      type="button"
      class="md:hidden relative w-11 h-11 flex items-center justify-center cursor-pointer bg-transparent border-none z-[110] rounded-lg focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-cyan/50"
      aria-label="Open menu"
      aria-expanded="false"
    >
      <div class="relative w-5 h-3.5">
        <span id="ham-top" class="absolute left-0 w-full h-px bg-sage/80 origin-center top-0 transition-[top,transform,opacity] duration-300" style="transition-timing-function: cubic-bezier(0.32, 0.72, 0, 1);"></span>
        <span id="ham-mid" class="absolute left-0 top-1/2 w-full h-px bg-sage/80 transition-[opacity,transform] duration-200" style="transition-timing-function: cubic-bezier(0.32, 0.72, 0, 1);"></span>
        <span id="ham-bot" class="absolute left-0 w-full h-px bg-sage/80 origin-center bottom-0 transition-[bottom,top,transform,opacity] duration-300" style="transition-timing-function: cubic-bezier(0.32, 0.72, 0, 1);"></span>
      </div>
    </button>
  </div>
</nav>

<!-- Mobile menu overlay -->
<div id="mobile-overlay" class="fixed inset-0 z-[99] md:hidden pointer-events-none opacity-0 transition-opacity duration-400" style="transition-timing-function: cubic-bezier(0.32, 0.72, 0, 1);">
  <!-- Backdrop -->
  <div id="mobile-backdrop" class="absolute inset-0 bg-bg/96 backdrop-blur-[24px] backdrop-saturate-[1.2]"></div>

  <!-- Menu content -->
  <div id="mobile-menu-content" class="relative flex flex-col items-center justify-center h-full gap-1 px-8" style="transform: translateY(-16px); transition: transform 0.5s cubic-bezier(0.32, 0.72, 0, 1);">
    {navItems.map((item, i) => (
      <a
        href={item.href}
        class="mobile-nav-link block py-4 font-d text-2xl tracking-[4px] uppercase text-white/80 no-underline cursor-pointer transition-colors duration-300 hover:text-cyan-dim opacity-0 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-cyan/50 focus-visible:rounded"
        style={`transform: translateY(12px); transition: opacity 0.45s ${0.08 + i * 0.06}s cubic-bezier(0.32, 0.72, 0, 1), transform 0.45s ${0.08 + i * 0.06}s cubic-bezier(0.32, 0.72, 0, 1), color 0.3s;`}
        data-delay-open={`opacity 0.45s ${0.08 + i * 0.06}s cubic-bezier(0.32, 0.72, 0, 1), transform 0.45s ${0.08 + i * 0.06}s cubic-bezier(0.32, 0.72, 0, 1), color 0.3s`}
        data-delay-close="opacity 0.2s cubic-bezier(0.32, 0.72, 0, 1), transform 0.2s cubic-bezier(0.32, 0.72, 0, 1), color 0.3s"
      >
        {item.label}
      </a>
    ))}

    <!-- Contact CTA -->
    <a
      href="/#contact"
      id="mobile-contact-cta"
      class="mobile-nav-link mt-8 font-m text-sm font-medium tracking-[2px] uppercase px-8 py-3 border border-cyan/30 text-cyan no-underline cursor-pointer hover:bg-cyan/[0.07] hover:border-cyan/50 rounded-lg opacity-0 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-cyan/50 focus-visible:rounded transition-[color,background-color,border-color] duration-300"
      style={`transform: translateY(12px); transition: opacity 0.45s ${0.08 + navItems.length * 0.06}s cubic-bezier(0.32, 0.72, 0, 1), transform 0.45s ${0.08 + navItems.length * 0.06}s cubic-bezier(0.32, 0.72, 0, 1), color 0.3s, background-color 0.3s, border-color 0.3s;`}
      data-delay-open={`opacity 0.45s ${0.08 + navItems.length * 0.06}s cubic-bezier(0.32, 0.72, 0, 1), transform 0.45s ${0.08 + navItems.length * 0.06}s cubic-bezier(0.32, 0.72, 0, 1), color 0.3s, background-color 0.3s, border-color 0.3s`}
      data-delay-close="opacity 0.2s cubic-bezier(0.32, 0.72, 0, 1), transform 0.2s cubic-bezier(0.32, 0.72, 0, 1), color 0.3s, background-color 0.3s, border-color 0.3s"
    >
      Let's Talk
    </a>

    <!-- Decorative bottom line -->
    <div id="mobile-decor-line" class="absolute bottom-12 left-1/2 -translate-x-1/2 w-16 h-px bg-gradient-to-r from-transparent via-cyan/25 to-transparent opacity-0" style="transition: opacity 0.6s 0.35s cubic-bezier(0.32, 0.72, 0, 1);"></div>
  </div>
</div>

<script>
  const hamburger = document.getElementById('hamburger-btn')!;
  const overlay = document.getElementById('mobile-overlay')!;
  const backdrop = document.getElementById('mobile-backdrop')!;
  const menuContent = document.getElementById('mobile-menu-content')!;
  const hamTop = document.getElementById('ham-top')!;
  const hamMid = document.getElementById('ham-mid')!;
  const hamBot = document.getElementById('ham-bot')!;
  const decorLine = document.getElementById('mobile-decor-line')!;
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('.mobile-nav-link');

  let isOpen = false;

  function openMenu() {
    isOpen = true;
    document.body.style.overflow = 'hidden';
    hamburger.setAttribute('aria-expanded', 'true');
    hamburger.setAttribute('aria-label', 'Close menu');

    // Overlay
    overlay.style.pointerEvents = 'auto';
    overlay.style.opacity = '1';

    // Menu content
    menuContent.style.transform = 'translateY(0)';

    // Hamburger → X
    hamTop.style.top = '50%';
    hamTop.style.transform = 'rotate(45deg)';
    hamMid.style.opacity = '0';
    hamMid.style.transform = 'scaleX(0)';
    hamBot.style.bottom = 'auto';
    hamBot.style.top = '50%';
    hamBot.style.transform = 'rotate(-45deg)';

    // Staggered nav links
    navLinks.forEach((link) => {
      const openTransition = link.dataset.delayOpen;
      if (openTransition) link.style.transition = openTransition;
      link.style.opacity = '1';
      link.style.transform = 'translateY(0)';
    });

    // Decorative line
    decorLine.style.opacity = '1';
  }

  function closeMenu() {
    isOpen = false;
    document.body.style.overflow = '';
    hamburger.setAttribute('aria-expanded', 'false');
    hamburger.setAttribute('aria-label', 'Open menu');

    // Overlay
    overlay.style.pointerEvents = 'none';
    overlay.style.opacity = '0';

    // Menu content
    menuContent.style.transform = 'translateY(-16px)';

    // Hamburger → lines
    hamTop.style.top = '0';
    hamTop.style.transform = 'none';
    hamMid.style.opacity = '1';
    hamMid.style.transform = 'scaleX(1)';
    hamBot.style.top = 'auto';
    hamBot.style.bottom = '0';
    hamBot.style.transform = 'none';

    // Nav links — quick close
    navLinks.forEach((link) => {
      const closeTransition = link.dataset.delayClose;
      if (closeTransition) link.style.transition = closeTransition;
      link.style.opacity = '0';
      link.style.transform = 'translateY(12px)';
    });

    // Decorative line
    decorLine.style.opacity = '0';
  }

  hamburger.addEventListener('click', () => {
    if (isOpen) closeMenu();
    else openMenu();
  });

  backdrop.addEventListener('click', closeMenu);

  navLinks.forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) closeMenu();
  });
</script>
