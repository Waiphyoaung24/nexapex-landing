---
// WordScroll — scroll-driven text fill + hover clip-path reveal
// Adapted from: minh-pham text clipping effect
---

<section class="ws relative z-20 w-full bg-bg" id="word-scroll">
  <p class="ws-label font-d">We Engineer</p>
  <div class="ws-items">
    {[
      'intelligent systems.',
      'computer vision.',
      'factory automation.',
      'autonomous robotics.',
      'neural networks.',
      'the future.',
    ].map((word) => (
      <h2 class="ws-text font-d">
        {word}
        <span>{word}</span>
      </h2>
    ))}
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    const textEls = gsap.utils.toArray<HTMLElement>('.ws-text');

    textEls.forEach((text) => {
      gsap.to(text, {
        backgroundSize: '100%',
        ease: 'none',
        scrollTrigger: {
          trigger: text,
          start: 'center 80%',
          end: 'center 20%',
          scrub: true,
        },
      });
    });
  }
</script>
