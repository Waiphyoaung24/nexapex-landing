---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'NexApex — AI Labs for Real-World Intelligence',
  description = 'Bangkok-based AI lab building intelligent systems for hospitality, manufacturing, and retail across Southeast Asia. From dynamic pricing to factory automation.',
  ogImage: ogImageProp,
} = Astro.props;

const siteName = 'NexApex';
const siteUrl = 'https://www.nexapex.ai';
const ogImage = ogImageProp ? (ogImageProp.startsWith('http') ? ogImageProp : `${siteUrl}${ogImageProp}`) : `${siteUrl}/full_color_logo.png`;
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image:width" content="1080" />
    <meta property="og:image:height" content="1080" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "NexApex",
      "url": "https://www.nexapex.ai",
      "logo": "https://www.nexapex.ai/full_color_logo.png",
      "description": description,
      "sameAs": []
    })}></script>
  </head>
  <body class="font-b bg-bg text-white overflow-x-hidden antialiased">
    <!-- Custom sci-fi cursor (desktop only) -->
    <div id="cursor-small" class="cursor-dot"></div>
    <div id="cursor-big" class="cursor-ring"></div>

    <slot />

    <!-- Lenis Smooth Scroll + GSAP ScrollTrigger sync -->
    <script>
      import Lenis from 'lenis';
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      const isTouch = 'ontouchstart' in window || (navigator.maxTouchPoints != null && navigator.maxTouchPoints > 0);

      // Only count 3D as heavy if the canvas is actually rendering (visible),
      // not just present in DOM (mobile hides it with display:none).
      const canvasWrapper = document.getElementById('canvas-wrapper');
      const hasHeavy3D = canvasWrapper != null && canvasWrapper.style.display !== 'none';
      const disableSyncTouch = isTouch && hasHeavy3D;

      // Normalize scroll speed across pages with different content heights.
      const docHeight = document.documentElement.scrollHeight;
      const vpHeight = window.innerHeight;
      const scrollPages = docHeight / vpHeight;
      const referencePages = 12;

      const isWorkPage = window.location.pathname.startsWith('/work');

      const lenis = new Lenis({
        duration: isWorkPage ? 1.0 : 1.2,
        easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true,
        wheelMultiplier: isWorkPage ? (isTouch ? 1.0 : 0.5) : 0.7,
        syncTouch: !disableSyncTouch,
        syncTouchLerp: isWorkPage ? 0.075 : 0.05,
        touchInertiaExponent: isWorkPage ? 1.5 : 1.2,
        touchMultiplier: isWorkPage ? (isTouch ? 1.0 : 0.5) : 0.6,
        virtualScroll: (e: { deltaY: number; deltaX: number }) => {
          // Skip speed normalization on work pages — they're shorter by design
          if (isWorkPage) return;
          if (scrollPages < referencePages) {
            const ratio = scrollPages / referencePages;
            const scale = Math.max(0.45, ratio * ratio);
            e.deltaY *= scale;
            e.deltaX *= scale;
          }
        },
      });

      // Sync Lenis scroll position → GSAP ScrollTrigger
      lenis.on('scroll', ScrollTrigger.update);
      // Handle initial hash scroll
      if (window.location.hash) {
        const target = document.querySelector(window.location.hash);
        if (target) {
          setTimeout(() => {
            lenis.scrollTo(target, { offset: -80, duration: 1.5 });
          }, 500);
        }
      }

      // Handle anchor clicks for cross-page or same-page smooth scroll
      document.querySelectorAll('a[href^="/#"], a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', (e) => {
          const href = anchor.getAttribute('href');
          const hash = href.includes('#') ? '#' + href.split('#')[1] : null;
          
          if (hash) {
            const target = document.querySelector(hash);
            const isHomePage = window.location.pathname === '/' || window.location.pathname === '/index.html';
            const isCrossPage = !href.startsWith('#') && !isHomePage;

            if (target && !isCrossPage) {
              e.preventDefault();
              lenis.scrollTo(target, { offset: -80, duration: 1.5 });
              if (history.pushState) {
                history.pushState(null, '', hash);
              }
            }
          }
        });
      });
    

      // Sync GSAP ticker → Lenis RAF
      gsap.ticker.add((time: number) => {
        lenis.raf(time * 1000);
      });

      // Disable Lenis's own RAF loop (GSAP ticker handles it now)
      gsap.ticker.lagSmoothing(0);
    </script>

    <!-- Custom cursor logic (desktop only) -->
    <script>
      const isTouch = 'ontouchstart' in window || (navigator.maxTouchPoints != null && navigator.maxTouchPoints > 0);

      if (!isTouch) {
        const dot = document.getElementById('cursor-small')!;
        const ring = document.getElementById('cursor-big')!;
        const interactives = document.querySelectorAll('a, button, [role="button"], .cursor-hover');

        document.addEventListener('mousemove', (e) => {
          dot.style.left = e.clientX + 'px';
          dot.style.top = e.clientY + 'px';
          ring.style.transform = `translate3d(calc(${e.clientX}px - 50%), calc(${e.clientY}px - 50%), 0)`;
        });

        document.addEventListener('mousedown', () => {
          ring.classList.add('cursor-click');
          dot.classList.add('cursor-dot--shrink');
        });

        document.addEventListener('mouseup', () => {
          ring.classList.remove('cursor-click');
          dot.classList.remove('cursor-dot--shrink');
        });

        interactives.forEach((el) => {
          el.addEventListener('mouseover', () => {
            ring.classList.add('cursor-ring--hover');
            dot.classList.add('cursor-dot--shrink');
          });
          el.addEventListener('mouseleave', () => {
            ring.classList.remove('cursor-ring--hover');
            dot.classList.remove('cursor-dot--shrink');
          });
        });

        document.documentElement.classList.add('custom-cursor');
      }
    </script>

    <!-- Scroll reveal animations for landing sections -->
    <script>
      import { initAllAnimations } from '../components/cinematic/scroll-animations';
      import { initAmbientEffects } from '../components/cinematic/ambient-effects';
      import { initProductAnimations } from '../components/cinematic/product-animations';

      function startAnimations() {
        initAllAnimations();
        initAmbientEffects();
        initProductAnimations();
      }

      function initWhenReady() {
        if (document.fonts && document.fonts.ready) {
          document.fonts.ready.then(startAnimations);
        } else {
          startAnimations();
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initWhenReady);
      } else {
        initWhenReady();
      }
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/globals.css';
</style>
