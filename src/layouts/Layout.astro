---
interface Props {
  title?: string;
  description?: string;
}

const { title = 'NEX APEX', description = 'AI Driven Premium Web Experience' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Google Fonts: fallback typefaces -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&family=Rajdhani:wght@300;400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body class="font-b bg-bg text-white overflow-x-hidden antialiased">
    <slot />

    <!-- Lenis Smooth Scroll + GSAP ScrollTrigger sync -->
    <script>
      import Lenis from 'lenis';
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      const lenis = new Lenis({
        duration: 1.2,
        easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true,
      });

      // Sync Lenis scroll position → GSAP ScrollTrigger
      lenis.on('scroll', ScrollTrigger.update);

      // Sync GSAP ticker → Lenis RAF
      gsap.ticker.add((time: number) => {
        lenis.raf(time * 1000);
      });

      // Disable Lenis's own RAF loop (GSAP ticker handles it now)
      gsap.ticker.lagSmoothing(0);
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/globals.css';
</style>
